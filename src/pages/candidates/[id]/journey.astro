---
import AppLayout from "../../../layouts/AppLayout.astro";
import { connectDB } from "../../../db/connection";
import { Candidate } from "../../../db/models/Candidate";
import { Interview } from "../../../db/models/Interview";
import { Assessment } from "../../../db/models/Assessment";
import { Types } from "mongoose";
import { sortedPipeline, findStage, getValidNextStages, getIconSvg, isHiredStage, getCandidateStageActions, type StageRecordStatus } from "../../../lib/pipeline";
import { scoreColorHex } from "../../../lib/scoreColor";

const { id } = Astro.params;
if (!id || !Types.ObjectId.isValid(id)) return Astro.redirect('/candidates');

await connectDB();
const raw = await Candidate.findById(id).populate('jobId', 'title pipeline').lean();
if (!raw) return Astro.redirect('/candidates');

const job = raw.jobId as any;
const pipeline = sortedPipeline(job?.pipeline || []);
const candidate = { ...raw, id: raw._id.toString(), jobTitle: job?.title || '' };
const applied = new Date(raw.createdAt).toISOString();
const currentStage = findStage(pipeline, candidate.currentStage);
const validStages = getValidNextStages(pipeline, candidate.currentStage);
// Once hired or rejected the process is over — neither "schedule another
// round" nor "reject"/"move stage" are sensible actions left to offer.
const isHired = !raw.rejected && isHiredStage(pipeline, raw.currentStage);
const canScheduleOrReject = !raw.rejected && !isHired;

const interviews = await Interview.find({ candidateId: id }).sort({ date: 1, time: 1 }).lean();
const interviewsByStage = new Map<string, typeof interviews>();
for (const iv of interviews) {
  const key = iv.pipelineStage || '';
  if (!interviewsByStage.has(key)) interviewsByStage.set(key, []);
  interviewsByStage.get(key)!.push(iv);
}

const assessments = await Assessment.find({ candidateId: id }).sort({ createdAt: 1 }).lean();
const assessmentsByStage = new Map<string, typeof assessments>();
for (const a of assessments) {
  const key = a.pipelineStage || '';
  if (!assessmentsByStage.has(key)) assessmentsByStage.set(key, []);
  assessmentsByStage.get(key)!.push(a);
}

// Per-stage record status — feeds getCandidateStageActions so only the
// action relevant to the candidate's actual current stage in the pipeline
// is offered, never both at once. A cancelled interview doesn't block
// re-scheduling, so it's treated as if it never happened.
const interviewStatusForStage = (stageKey: string): StageRecordStatus => {
  const docs = (interviewsByStage.get(stageKey) || []).filter(iv => iv.status !== 'cancelled');
  if (!docs.length) return 'none';
  return docs.some(iv => iv.status === 'completed') ? 'done' : 'pending';
};
const assessmentStatusForStage = (stageKey: string): StageRecordStatus => {
  const docs = assessmentsByStage.get(stageKey) || [];
  if (!docs.length) return 'none';
  return docs.some(a => a.status === 'evaluated') ? 'done' : 'pending';
};
const stageActions = canScheduleOrReject
  ? getCandidateStageActions(pipeline, raw.currentStage, interviewStatusForStage, assessmentStatusForStage)
  : { canScheduleInterview: false, canScheduleAssessment: false };
const canScheduleInterview = stageActions.canScheduleInterview;
const canScheduleAssessment = stageActions.canScheduleAssessment;

// The journey is built entirely from real records: an implicit "arrived at the
// first stage" event from createdAt, then every real stageHistory transition in
// order, each carrying its mover/timestamp/notes — no fabricated steps.
type TimelineEvent = {
  type: 'arrival' | 'rejection';
  stageKey?: string;
  stageLabel?: string;
  color?: string;
  icon?: string;
  fromLabel?: string;
  at: Date | string;
  movedBy?: string;
  notes?: string;
  isInitial?: boolean;
  skippedStages?: { key: string; label: string }[];
};

const events: TimelineEvent[] = [];
const firstStage = pipeline[0];
if (firstStage) {
  events.push({
    type: 'arrival',
    stageKey: firstStage.key,
    stageLabel: firstStage.label,
    color: firstStage.color,
    icon: firstStage.icon,
    at: raw.createdAt,
    isInitial: true,
  });
}
for (const h of (candidate.stageHistory || [])) {
  const stage = findStage(pipeline, h.stageKey);
  const fromStage = findStage(pipeline, h.fromStageKey);
  // A jump that lands past intermediate stages (e.g. Applied straight to Hired)
  // is recorded as a deliberate skip on this transition — not as "pending" work
  // still to come, which would render confusingly below a terminal stage.
  const skippedStages = (fromStage && stage && stage.order > fromStage.order + 1)
    ? sortedPipeline(pipeline)
        .filter(s => s.order > fromStage.order && s.order < stage.order)
        .map(s => ({ key: s.key, label: s.label }))
    : [];
  events.push({
    type: 'arrival',
    stageKey: h.stageKey,
    stageLabel: h.stageLabel || stage?.label || h.stageKey,
    color: stage?.color || '#6b7280',
    icon: stage?.icon || 'circle',
    fromLabel: h.fromStageLabel,
    at: h.movedAt,
    movedBy: h.movedBy,
    notes: h.notes,
    skippedStages,
  });
}
if (candidate.rejected) {
  events.push({ type: 'rejection', at: candidate.rejectedAt || raw.updatedAt, movedBy: candidate.rejectedBy });
}

const visitedKeys = new Set(events.filter(e => e.type === 'arrival').map(e => e.stageKey));
const currentOrder = currentStage ? currentStage.order : -1;
// Only stages still ahead of the candidate's current position are genuinely
// "pending" — anything behind that was never visited was deliberately skipped
// and is already called out inline on the transition that jumped over it.
const pendingStages = candidate.rejected ? [] : pipeline.filter(s => !visitedKeys.has(s.key) && s.order > currentOrder);

const fmt = (d: Date | string) => {
  const date = new Date(d);
  return isNaN(date.getTime()) ? '' : date.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
};

// Position in the pipeline reflects where the candidate actually stands today —
// not how many arrival events fired, which would undercount when stages were skipped.
const stepNumber = currentOrder + 1;
const totalSteps = pipeline.length || 1;
---

<AppLayout title={`${candidate.name} · Journey`} activeNav="candidates">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;">
    <a href={`/candidates/${candidate.id}`} class="btn btn-ghost btn-sm" style="padding:0;width:28px;height:28px;border-radius:6px;border:1px solid var(--border);">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <div>
      <h1 style="font-size:22px;font-weight:600;color:var(--fg);letter-spacing:-0.4px;margin:0;">Candidate Journey</h1>
      <p style="font-size:13px;color:var(--fg-mute);margin:4px 0 0;">{candidate.name} · {candidate.jobTitle}</p>
    </div>
  </div>

  <div class="grid-main-aside" style="--aside-w:260px;gap:24px;">
    <div class="card shadow-lvl-2">
      {events.length === 0 ? (
        <div class="empty-state" style="padding:32px;">
          <div style="font-size:15px;font-weight:500;color:var(--fg);margin-bottom:4px;">No journey yet</div>
          <div style="font-size:13px;">This job has no configured pipeline, so there's nothing to track.</div>
        </div>
      ) : (
        <div class="timeline">
          {events.map((ev, i) => {
            const isLast = i === events.length - 1 && pendingStages.length === 0;
            const stageInterviews = ev.type === 'arrival' ? (interviewsByStage.get(ev.stageKey || '') || []) : [];
            const stageAssessments = ev.type === 'arrival' ? (assessmentsByStage.get(ev.stageKey || '') || []) : [];
            return (
              <div class="timeline-item" style={isLast ? 'padding-bottom:0;' : ''}>
                <div class="timeline-dot completed" style={ev.type === 'rejection' ? 'border-color:#ef4444;background:#ef4444;' : `border-color:${ev.color};background:${ev.color};`}>
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M2 5l2.5 2.5 3.5-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div style={`padding:2px 0 ${isLast ? '0' : '24px'};`}>
                  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px;">
                    {ev.type === 'rejection' ? (
                      <span style="font-size:14px;font-weight:600;color:#ef4444;">Rejected</span>
                    ) : (
                      <span style="font-size:14px;font-weight:600;color:var(--fg);display:flex;align-items:center;gap:6px;">
                        <span set:html={getIconSvg(ev.icon || 'circle')} style={`color:${ev.color};display:inline-flex;`} />
                        {ev.stageLabel}
                      </span>
                    )}
                    {ev.type === 'arrival' && ev.stageKey === candidate.currentStage && !candidate.rejected && <span class="badge badge-info" style="font-size:11px;">Current</span>}
                    <span style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;">{fmt(ev.at)}</span>
                  </div>
                  <p style="font-size:13px;color:var(--fg-body);margin:0 0 6px;line-height:1.5;">
                    {ev.type === 'rejection'
                      ? `Marked as rejected${ev.movedBy ? ` by ${ev.movedBy}` : ''}.`
                      : ev.isInitial
                        ? `Resume uploaded — entered the pipeline at "${ev.stageLabel}". AI score: ${candidate.score} · ${candidate.recommendation}.`
                        : `Moved from "${ev.fromLabel || 'the start'}" to "${ev.stageLabel}"${ev.movedBy ? ` by ${ev.movedBy}` : ''}.`}
                  </p>
                  {ev.skippedStages && ev.skippedStages.length > 0 && (
                    <div style="font-size:12px;color:var(--fg-mute);background:var(--bg-soft);border:1px dashed var(--border);border-radius:6px;padding:8px 10px;margin-bottom:6px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                      <span class="badge badge-neutral" style="font-size:11px;flex-shrink:0;">Skipped</span>
                      <span>Jumped past {ev.skippedStages.map(s => s.label).join(', ')} on the way to "{ev.stageLabel}".</span>
                    </div>
                  )}
                  {ev.notes && (
                    <div style="font-size:12px;color:var(--fg-body);background:var(--bg-soft);border:1px solid var(--border);border-radius:6px;padding:8px 10px;margin-bottom:6px;">
                      <span style="color:var(--fg-mute);">Note:</span> {ev.notes}
                    </div>
                  )}
                  {stageInterviews.length > 0 && (
                    <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
                      {stageInterviews.map(iv => (
                        <a href={`/interviews/${iv._id.toString()}`} style="display:flex;flex-direction:column;gap:8px;padding:10px 12px;border-radius:6px;background:var(--bg-soft);border:1px solid var(--border);text-decoration:none;">
                          <div style="display:flex;align-items:center;gap:10px;">
                            <div>
                              <div style="font-size:13px;font-weight:500;color:var(--fg);">{iv.round}</div>
                              <div style="font-size:12px;color:var(--fg-mute);">{iv.date} · {iv.time} · {iv.interviewer}</div>
                            </div>
                            <span class={`badge ${iv.status === 'completed' ? 'badge-success' : iv.status === 'cancelled' ? 'badge-neutral' : 'badge-info'}`} style="margin-left:auto;flex-shrink:0;">{iv.status}</span>
                          </div>
                          {iv.status === 'completed' && iv.techScore > 0 && (
                            <div style="display:flex;gap:14px;flex-wrap:wrap;font-size:11px;font-family:'JetBrains Mono',monospace;">
                              <span style={`color:${scoreColorHex(iv.techScore)};`}>Tech: {iv.techScore}</span>
                              <span style={`color:${scoreColorHex(iv.commScore)};`}>Comm: {iv.commScore}</span>
                              <span style={`color:${scoreColorHex(iv.confidenceScore)};`}>Conf: {iv.confidenceScore}</span>
                            </div>
                          )}
                          {iv.analysis && (
                            <div style="display:flex;flex-direction:column;gap:4px;">
                              <div style="display:flex;align-items:center;gap:8px;">
                                <span class={`badge ${iv.analysis.decision === 'advance' ? 'badge-success' : 'badge-error'}`} style="font-size:11px;">
                                  {iv.analysis.decision === 'advance' ? 'Recommended to advance' : 'Recommended to hold'}
                                </span>
                              </div>
                              {iv.analysis.strengths?.length > 0 && (
                                <div style="font-size:12px;color:var(--fg-body);line-height:1.5;">
                                  <span style="color:#10b981;">Strengths:</span> {iv.analysis.strengths.join('; ')}
                                </div>
                              )}
                              {iv.analysis.concerns?.length > 0 && (
                                <div style="font-size:12px;color:var(--fg-body);line-height:1.5;">
                                  <span style="color:#ef4444;">Concerns:</span> {iv.analysis.concerns.join('; ')}
                                </div>
                              )}
                              {iv.analysis.reasoning && (
                                <div style="font-size:12px;color:var(--fg-mute);line-height:1.5;">{iv.analysis.reasoning}</div>
                              )}
                            </div>
                          )}
                        </a>
                      ))}
                    </div>
                  )}
                  {stageAssessments.length > 0 && (
                    <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
                      {stageAssessments.map(a => (
                        <a href={`/assessments/${a._id.toString()}`} style="display:flex;flex-direction:column;gap:8px;padding:10px 12px;border-radius:6px;background:var(--bg-soft);border:1px solid var(--border);text-decoration:none;">
                          <div style="display:flex;align-items:center;gap:10px;">
                            <div>
                              <div style="font-size:13px;font-weight:500;color:var(--fg);">{a.round}</div>
                              <div style="font-size:12px;color:var(--fg-mute);">{a.type}{a.testsTotal > 0 ? ` · ${a.testsPassed}/${a.testsTotal} tests passed` : ''}</div>
                            </div>
                            <span class={`badge ${a.status === 'evaluated' ? 'badge-success' : a.status === 'submitted' ? 'badge-info' : 'badge-neutral'}`} style="margin-left:auto;flex-shrink:0;">{a.status}</span>
                          </div>
                          {a.status === 'evaluated' && a.overallScore > 0 && (
                            <div style="display:flex;gap:14px;flex-wrap:wrap;font-size:11px;font-family:'JetBrains Mono',monospace;">
                              <span style={`color:${scoreColorHex(a.overallScore)};`}>Overall: {a.overallScore}</span>
                              {a.codeQualityScore > 0 && <span style={`color:${scoreColorHex(a.codeQualityScore)};`}>Code Quality: {a.codeQualityScore}</span>}
                              {a.algorithmScore > 0 && <span style={`color:${scoreColorHex(a.algorithmScore)};`}>Algorithm: {a.algorithmScore}</span>}
                              {a.problemSolvingScore > 0 && <span style={`color:${scoreColorHex(a.problemSolvingScore)};`}>Problem Solving: {a.problemSolvingScore}</span>}
                            </div>
                          )}
                          {a.analysis && (
                            <div style="display:flex;flex-direction:column;gap:4px;">
                              <div style="display:flex;align-items:center;gap:8px;">
                                <span class={`badge ${a.analysis.decision === 'advance' ? 'badge-success' : 'badge-error'}`} style="font-size:11px;">
                                  {a.analysis.decision === 'advance' ? 'Recommended to advance' : 'Recommended to hold'}
                                </span>
                              </div>
                              {a.analysis.strengths?.length > 0 && (
                                <div style="font-size:12px;color:var(--fg-body);line-height:1.5;">
                                  <span style="color:#10b981;">Strengths:</span> {a.analysis.strengths.join('; ')}
                                </div>
                              )}
                              {a.analysis.concerns?.length > 0 && (
                                <div style="font-size:12px;color:var(--fg-body);line-height:1.5;">
                                  <span style="color:#ef4444;">Concerns:</span> {a.analysis.concerns.join('; ')}
                                </div>
                              )}
                              {a.analysis.reasoning && (
                                <div style="font-size:12px;color:var(--fg-mute);line-height:1.5;">{a.analysis.reasoning}</div>
                              )}
                            </div>
                          )}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
          {pendingStages.map((stage, i) => (
            <div class="timeline-item" style={i === pendingStages.length - 1 ? 'padding-bottom:0;' : ''}>
              <div class="timeline-dot"></div>
              <div style={`padding:2px 0 ${i < pendingStages.length - 1 ? '24px' : '0'};`}>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px;">
                  <span style="font-size:14px;font-weight:400;color:var(--fg-mute);display:flex;align-items:center;gap:6px;">
                    <span set:html={getIconSvg(stage.icon)} style="display:inline-flex;opacity:0.5;" />
                    {stage.label}
                  </span>
                  <span class="badge badge-neutral" style="font-size:11px;">Pending</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <div style="display:flex;flex-direction:column;gap:16px;">
      <div class="card shadow-lvl-2">
        <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Current Stage</h3>
        {candidate.rejected ? (
          <>
            <div style="font-size:20px;font-weight:600;color:#ef4444;margin-bottom:4px;">Rejected</div>
            <button id="unreject-btn" class="btn btn-ghost" style="width:100%;margin-top:8px;">Undo Rejection</button>
          </>
        ) : (
          <>
            <div style="font-size:20px;font-weight:600;color:var(--fg);margin-bottom:4px;">{currentStage?.label || candidate.currentStage}</div>
            <div style="font-size:13px;color:var(--fg-mute);">Step {stepNumber} of {totalSteps}</div>
            <div class="progress" style="margin-top:12px;">
              <div class="progress-bar" style={`width:${Math.round(stepNumber / totalSteps * 100)}%`}></div>
            </div>
          </>
        )}
      </div>

      {canScheduleOrReject && validStages.length > 0 && (
        <div class="card shadow-lvl-2">
          <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Move to Stage</h3>
          <select id="stage-select" class="select" style="margin-bottom:10px;">
            {validStages.map(s => (
              <option value={s.key} selected={candidate.currentStage === s.key}>{s.label}</option>
            ))}
          </select>
          <button id="move-stage-btn" class="btn btn-primary" style="width:100%;border-radius:6px;">Update Stage</button>
          <button id="reject-btn" class="btn btn-ghost" style="width:100%;color:#ef4444;margin-top:8px;">Reject Candidate</button>
        </div>
      )}

      {canScheduleInterview && (
        <div class="card shadow-lvl-2">
          <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Schedule Interview</h3>
          <a href={`/interviews/schedule?candidate=${candidate.id}`} class="btn btn-secondary" style="width:100%;border-radius:6px;">Schedule Next Round</a>
        </div>
      )}
      {canScheduleAssessment && (
        <div class="card shadow-lvl-2">
          <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Create Assessment</h3>
          <a href={`/assessments/create?candidate=${candidate.id}`} class="btn btn-secondary" style="width:100%;border-radius:6px;">Create Assessment</a>
        </div>
      )}
    </div>
  </div>
</AppLayout>

<script define:vars={{ candidateId: candidate.id }}>
  async function moveCandidateStage(currentStage, notes, extra = {}) {
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentStage, notes, ...extra }),
    });
    if (res.ok) {
      window.location.reload();
      return;
    }
    const err = await res.json().catch(() => ({}));
    // The API blocks moving someone past the interview/assessment stage with
    // no analyzed result on file — surfacing that gap here, with a deliberate
    // way past it, rather than letting the stage and the AI read silently
    // fall out of sync.
    if (err.code === 'NO_ANALYZED_INTERVIEW' || err.code === 'NO_ANALYZED_ASSESSMENT') {
      const proceed = await window.hvConfirm({
        title: err.code === 'NO_ANALYZED_ASSESSMENT' ? 'No analyzed assessment on record' : 'No analyzed interview on record',
        message: `${err.error}\n\nMove them anyway?`,
        confirmLabel: 'Move anyway',
        cancelLabel: 'Go add feedback first',
        destructive: true,
      });
      if (proceed) {
        const confirmFlag = err.code === 'NO_ANALYZED_ASSESSMENT' ? 'confirmSkipAssessment' : 'confirmSkipInterview';
        await moveCandidateStage(currentStage, notes, { [confirmFlag]: true });
      }
      return;
    }
    window.hvToast(err.error || 'Failed to update stage.', 'error');
  }

  document.getElementById('move-stage-btn')?.addEventListener('click', async () => {
    const currentStage = document.getElementById('stage-select').value;
    const notes = await window.hvPrompt({
      title: 'Move candidate',
      message: 'Add an optional note about this move (visible on this journey):',
      placeholder: 'e.g. Strong portfolio, moving to next round',
      confirmLabel: 'Move',
    });
    if (notes === null) return;
    await moveCandidateStage(currentStage, notes, {});
  });

  document.getElementById('reject-btn')?.addEventListener('click', async () => {
    const ok = await window.hvConfirm({
      title: 'Reject candidate',
      message: 'Reject this candidate? This can be undone later from this page if needed.',
      confirmLabel: 'Reject',
      destructive: true,
    });
    if (!ok) return;
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rejected: true }),
    });
    if (res.ok) window.location.reload();
    else {
      const err = await res.json().catch(() => ({}));
      window.hvToast(err.error || 'Failed to reject candidate.', 'error');
    }
  });

  document.getElementById('unreject-btn')?.addEventListener('click', async () => {
    const ok = await window.hvConfirm({
      title: 'Undo rejection',
      message: 'Move this candidate back into the active pipeline?',
      confirmLabel: 'Undo Rejection',
    });
    if (!ok) return;
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rejected: false }),
    });
    if (res.ok) window.location.reload();
    else {
      const err = await res.json().catch(() => ({}));
      window.hvToast(err.error || 'Failed to undo rejection.', 'error');
    }
  });
</script>
