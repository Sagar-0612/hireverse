---
import AppLayout from "../../../layouts/AppLayout.astro";
import { connectDB } from "../../../db/connection";
import { Candidate } from "../../../db/models/Candidate";
import { Interview } from "../../../db/models/Interview";
import { Types } from "mongoose";
import { sortedPipeline, findStage, getValidNextStages, getIconSvg } from "../../../lib/pipeline";

const { id } = Astro.params;
if (!id || !Types.ObjectId.isValid(id)) return Astro.redirect('/candidates');

await connectDB();
const raw = await Candidate.findById(id).populate('jobId', 'title pipeline').lean();
if (!raw) return Astro.redirect('/candidates');

const job = raw.jobId as any;
const pipeline = sortedPipeline(job?.pipeline || []);
const candidate = { ...raw, id: raw._id.toString(), jobTitle: job?.title || '' };
const applied = new Date(raw.createdAt).toISOString();
const currentStage = findStage(pipeline, candidate.currentStage);
const validStages = getValidNextStages(pipeline, candidate.currentStage);

const interviews = await Interview.find({ candidateId: id }).sort({ date: 1, time: 1 }).lean();
const interviewsByStage = new Map<string, typeof interviews>();
for (const iv of interviews) {
  const key = iv.pipelineStage || '';
  if (!interviewsByStage.has(key)) interviewsByStage.set(key, []);
  interviewsByStage.get(key)!.push(iv);
}

// The journey is built entirely from real records: an implicit "arrived at the
// first stage" event from createdAt, then every real stageHistory transition in
// order, each carrying its mover/timestamp/notes — no fabricated steps.
type TimelineEvent = {
  type: 'arrival' | 'rejection';
  stageKey?: string;
  stageLabel?: string;
  color?: string;
  icon?: string;
  fromLabel?: string;
  at: Date | string;
  movedBy?: string;
  notes?: string;
  isInitial?: boolean;
};

const events: TimelineEvent[] = [];
const firstStage = pipeline[0];
if (firstStage) {
  events.push({
    type: 'arrival',
    stageKey: firstStage.key,
    stageLabel: firstStage.label,
    color: firstStage.color,
    icon: firstStage.icon,
    at: raw.createdAt,
    isInitial: true,
  });
}
for (const h of (candidate.stageHistory || [])) {
  const stage = findStage(pipeline, h.stageKey);
  events.push({
    type: 'arrival',
    stageKey: h.stageKey,
    stageLabel: h.stageLabel || stage?.label || h.stageKey,
    color: stage?.color || '#6b7280',
    icon: stage?.icon || 'circle',
    fromLabel: h.fromStageLabel,
    at: h.movedAt,
    movedBy: h.movedBy,
    notes: h.notes,
  });
}
if (candidate.rejected) {
  events.push({ type: 'rejection', at: candidate.rejectedAt || raw.updatedAt, movedBy: candidate.rejectedBy });
}

const visitedKeys = new Set(events.filter(e => e.type === 'arrival').map(e => e.stageKey));
const pendingStages = candidate.rejected ? [] : pipeline.filter(s => !visitedKeys.has(s.key));

const fmt = (d: Date | string) => {
  const date = new Date(d);
  return isNaN(date.getTime()) ? '' : date.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
};

const stepNumber = events.filter(e => e.type === 'arrival').length;
const totalSteps = pipeline.length || 1;
---

<AppLayout title={`${candidate.name} · Journey`} activeNav="candidates">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;">
    <a href={`/candidates/${candidate.id}`} class="btn btn-ghost btn-sm" style="padding:0;width:28px;height:28px;border-radius:6px;border:1px solid var(--border);">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <div>
      <h1 style="font-size:22px;font-weight:600;color:var(--fg);letter-spacing:-0.4px;margin:0;">Candidate Journey</h1>
      <p style="font-size:13px;color:var(--fg-mute);margin:4px 0 0;">{candidate.name} · {candidate.jobTitle}</p>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 260px;gap:24px;align-items:start;">
    <div class="card shadow-lvl-2">
      {events.length === 0 ? (
        <div class="empty-state" style="padding:32px;">
          <div style="font-size:15px;font-weight:500;color:var(--fg);margin-bottom:4px;">No journey yet</div>
          <div style="font-size:13px;">This job has no configured pipeline, so there's nothing to track.</div>
        </div>
      ) : (
        <div class="timeline">
          {events.map((ev, i) => {
            const isLast = i === events.length - 1 && pendingStages.length === 0;
            const stageInterviews = ev.type === 'arrival' ? (interviewsByStage.get(ev.stageKey || '') || []) : [];
            return (
              <div class="timeline-item" style={isLast ? 'padding-bottom:0;' : ''}>
                <div class="timeline-dot completed" style={ev.type === 'rejection' ? 'border-color:#ef4444;background:#ef4444;' : `border-color:${ev.color};background:${ev.color};`}>
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M2 5l2.5 2.5 3.5-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div style={`padding:2px 0 ${isLast ? '0' : '24px'};`}>
                  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px;">
                    {ev.type === 'rejection' ? (
                      <span style="font-size:14px;font-weight:600;color:#ef4444;">Rejected</span>
                    ) : (
                      <span style="font-size:14px;font-weight:600;color:var(--fg);display:flex;align-items:center;gap:6px;">
                        <span set:html={getIconSvg(ev.icon || 'circle')} style={`color:${ev.color};display:inline-flex;`} />
                        {ev.stageLabel}
                      </span>
                    )}
                    {ev.type === 'arrival' && ev.stageKey === candidate.currentStage && !candidate.rejected && <span class="badge badge-info" style="font-size:11px;">Current</span>}
                    <span style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;">{fmt(ev.at)}</span>
                  </div>
                  <p style="font-size:13px;color:var(--fg-body);margin:0 0 6px;line-height:1.5;">
                    {ev.type === 'rejection'
                      ? `Marked as rejected${ev.movedBy ? ` by ${ev.movedBy}` : ''}.`
                      : ev.isInitial
                        ? `Resume uploaded — entered the pipeline at "${ev.stageLabel}". AI score: ${candidate.score} · ${candidate.recommendation}.`
                        : `Moved from "${ev.fromLabel || 'the start'}" to "${ev.stageLabel}"${ev.movedBy ? ` by ${ev.movedBy}` : ''}.`}
                  </p>
                  {ev.notes && (
                    <div style="font-size:12px;color:var(--fg-body);background:var(--bg-soft);border:1px solid var(--border);border-radius:6px;padding:8px 10px;margin-bottom:6px;">
                      <span style="color:var(--fg-mute);">Note:</span> {ev.notes}
                    </div>
                  )}
                  {stageInterviews.length > 0 && (
                    <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
                      {stageInterviews.map(iv => (
                        <a href={`/interviews/${iv._id.toString()}`} style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:6px;background:var(--bg-soft);border:1px solid var(--border);text-decoration:none;">
                          <div>
                            <div style="font-size:13px;font-weight:500;color:var(--fg);">{iv.round}</div>
                            <div style="font-size:12px;color:var(--fg-mute);">{iv.date} · {iv.time} · {iv.interviewer}</div>
                            {iv.status === 'completed' && iv.techScore > 0 && (
                              <div style="font-size:11px;color:var(--fg-mute);margin-top:2px;font-family:'JetBrains Mono',monospace;">
                                Tech: {iv.techScore} · Comm: {iv.commScore} · Conf: {iv.confidenceScore}
                              </div>
                            )}
                          </div>
                          <span class={`badge ${iv.status === 'completed' ? 'badge-success' : 'badge-info'}`} style="margin-left:auto;flex-shrink:0;">{iv.status}</span>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
          {pendingStages.map((stage, i) => (
            <div class="timeline-item" style={i === pendingStages.length - 1 ? 'padding-bottom:0;' : ''}>
              <div class="timeline-dot"></div>
              <div style={`padding:2px 0 ${i < pendingStages.length - 1 ? '24px' : '0'};`}>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px;">
                  <span style="font-size:14px;font-weight:400;color:var(--fg-mute);display:flex;align-items:center;gap:6px;">
                    <span set:html={getIconSvg(stage.icon)} style="display:inline-flex;opacity:0.5;" />
                    {stage.label}
                  </span>
                  <span class="badge badge-neutral" style="font-size:11px;">Pending</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <div style="display:flex;flex-direction:column;gap:16px;">
      <div class="card shadow-lvl-2">
        <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Current Stage</h3>
        {candidate.rejected ? (
          <div style="font-size:20px;font-weight:600;color:#ef4444;margin-bottom:4px;">Rejected</div>
        ) : (
          <>
            <div style="font-size:20px;font-weight:600;color:var(--fg);margin-bottom:4px;">{currentStage?.label || candidate.currentStage}</div>
            <div style="font-size:13px;color:var(--fg-mute);">Step {stepNumber} of {totalSteps}</div>
            <div class="progress" style="margin-top:12px;">
              <div class="progress-bar" style={`width:${Math.round(stepNumber / totalSteps * 100)}%`}></div>
            </div>
          </>
        )}
      </div>

      {!candidate.rejected && validStages.length > 0 && (
        <div class="card shadow-lvl-2">
          <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Move to Stage</h3>
          <select id="stage-select" class="select" style="margin-bottom:10px;">
            {validStages.map(s => (
              <option value={s.key} selected={candidate.currentStage === s.key}>{s.label}</option>
            ))}
          </select>
          <button id="move-stage-btn" class="btn btn-primary" style="width:100%;border-radius:6px;">Update Stage</button>
          <button id="reject-btn" class="btn btn-ghost" style="width:100%;color:#ef4444;margin-top:8px;">Reject Candidate</button>
        </div>
      )}

      <div class="card shadow-lvl-2">
        <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Schedule Interview</h3>
        <a href={`/interviews/schedule?candidate=${candidate.id}`} class="btn btn-secondary" style="width:100%;border-radius:6px;">Schedule Next Round</a>
      </div>
    </div>
  </div>
</AppLayout>

<script define:vars={{ candidateId: candidate.id }}>
  document.getElementById('move-stage-btn')?.addEventListener('click', async () => {
    const currentStage = document.getElementById('stage-select').value;
    const notes = prompt('Add an optional note about this move (visible on this journey):') || '';
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentStage, notes }),
    });
    if (res.ok) window.location.reload();
    else {
      const err = await res.json().catch(() => ({}));
      alert(err.error || 'Failed to update stage.');
    }
  });

  document.getElementById('reject-btn')?.addEventListener('click', async () => {
    if (!confirm('Reject this candidate? This is a terminal action and cannot be undone.')) return;
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rejected: true }),
    });
    if (res.ok) window.location.reload();
    else {
      const err = await res.json().catch(() => ({}));
      alert(err.error || 'Failed to reject candidate.');
    }
  });
</script>
