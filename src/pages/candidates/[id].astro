---
import AppLayout from "../../layouts/AppLayout.astro";
import { connectDB } from "../../db/connection";
import { Candidate } from "../../db/models/Candidate";
import { Interview } from "../../db/models/Interview";
import { Types } from "mongoose";
import { sortedPipeline, getValidNextStages, findStage, getIconSvg, isHiredStage } from "../../lib/pipeline";
import { buildCandidateSummary } from "../../lib/candidateSummary";

const { id } = Astro.params;
if (!id || !Types.ObjectId.isValid(id)) return Astro.redirect('/candidates');

await connectDB();
const raw = await Candidate.findById(id).populate('jobId', 'title department location requiredSkills niceToHaveSkills education level pipeline').lean();
if (!raw) return Astro.redirect('/candidates');

const job = raw.jobId as any;
const pipeline = sortedPipeline(job?.pipeline || []);
const currentStage = findStage(pipeline, raw.currentStage);
const validStages = getValidNextStages(pipeline, raw.currentStage);
// Once hired or rejected the process is over — neither "schedule another
// round" nor "reject" are sensible actions left to offer.
const isHired = !raw.rejected && isHiredStage(pipeline, raw.currentStage);
const canScheduleOrReject = !raw.rejected && !isHired;

const interviewDocs = await Interview.find({ candidateId: id }).sort({ date: 1, time: 1 }).lean();

// The most recent human-written stage-move remark — auto-advance notes are
// system-generated filler, not a recruiter's actual read, so they're excluded.
// This is what makes the assessment "dynamic per stage": real notes/feedback
// recorded as the candidate moves get folded into the next read of them.
const humanStageNotes = (raw.stageHistory || [])
  .filter((h: any) => h.notes && h.notes.trim() && !/^auto-advanced/i.test(h.notes.trim()))
  .sort((a: any, b: any) => new Date(b.movedAt).getTime() - new Date(a.movedAt).getTime());
const latestStageNote = humanStageNotes.length ? {
  stageLabel: humanStageNotes[0].stageLabel,
  note: humanStageNotes[0].notes,
  movedBy: humanStageNotes[0].movedBy,
  movedAt: humanStageNotes[0].movedAt,
} : null;

const summary = buildCandidateSummary({
  name: raw.name,
  score: raw.score,
  skillsMatch: raw.skillsMatch,
  educationMatch: raw.educationMatch,
  experience: raw.experience,
  recommendation: raw.recommendation,
  currentStage: raw.currentStage,
  rejected: raw.rejected,
  rejectedAt: raw.rejectedAt,
  rejectedBy: raw.rejectedBy,
  pipeline,
  matchedSkills: raw.skills || [],
  practicalSkills: raw.practicalSkills || [],
  achievements: raw.achievements || [],
  jobRequiredSkills: job?.requiredSkills || [],
  jobNiceToHaveSkills: job?.niceToHaveSkills || [],
  jobLevel: job?.level || '',
  latestStageNote,
  interviews: interviewDocs.map(iv => ({
    round: iv.round,
    date: iv.date,
    status: iv.status,
    commScore: iv.commScore,
    techScore: iv.techScore,
    confidenceScore: iv.confidenceScore,
    recommendation: iv.recommendation,
    analysis: iv.analysis ? {
      decision: iv.analysis.decision,
      strengths: iv.analysis.strengths,
      concerns: iv.analysis.concerns,
      reasoning: iv.analysis.reasoning,
    } : null,
  })),
});
const verdictBadgeClass = (summary.verdict === 'advance' || summary.verdict === 'hired') ? 'badge-success' : summary.verdict === 'rejected' ? 'badge-error' : summary.verdict === 'early' ? 'badge-info' : 'badge-warning';

const candidate = {
  ...raw,
  id: raw._id.toString(),
  jobId: job?._id?.toString() || '',
  jobTitle: job?.title || '',
  jobDept: job?.department || '',
  jobSkills: job?.requiredSkills || [],
  jobEducation: job?.education || '',
  jobLevel: job?.level || '',
  applied: new Date(raw.createdAt).toISOString().split('T')[0],
};

// Three real, inspectable tiers — not a guess: a skill that's nowhere on the
// resume scores 0 (not "20% just for being asked about"); one that's merely
// named scores moderately; one with real evidence of hands-on use (built into
// a project, "Tech Stack:", etc. — see practicalSkills) scores high. Every
// number traces back to whether the resume's own text actually supports it.
const skillsToShow = candidate.jobSkills.length ? candidate.jobSkills : (candidate.skills || []);
const skillStatus = skillsToShow.map((skill: string) => {
  const matched = (candidate.skills || []).some((s: string) => s.toLowerCase() === skill.toLowerCase());
  if (!matched) return { score: 0, label: 'Not found on resume' };
  const demonstrated = (candidate.practicalSkills || []).some((s: string) => s.toLowerCase() === skill.toLowerCase());
  return demonstrated
    ? { score: 95, label: 'Used in a project or role — not just listed' }
    : { score: 55, label: 'Listed, but no project/work evidence found' };
});
---

<AppLayout title={candidate.name} activeNav="candidates">
  <div style="display:flex;align-items:flex-start;gap:12px;margin-bottom:28px;">
    <a href="/candidates" class="btn btn-ghost btn-sm" style="padding:0;width:28px;height:28px;border-radius:6px;border:1px solid var(--border);flex-shrink:0;margin-top:4px;">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <div style="flex:1;min-width:0;">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <div class="avatar" style="width:44px;height:44px;font-size:16px;">{candidate.name.split(' ').map((n: string) => n[0]).join('')}</div>
        <div>
          <h1 style="font-size:22px;font-weight:600;color:var(--fg);letter-spacing:-0.4px;margin:0;">{candidate.name}</h1>
          <div style="font-size:13px;color:var(--fg-mute);margin-top:2px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
            <span>{candidate.location}</span>
            <span>· Applied {candidate.applied}</span>
          </div>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:8px;flex-shrink:0;">
      <a href={`/candidates/${candidate.id}/journey`} class="btn btn-secondary btn-sm">Journey</a>
      {canScheduleOrReject && <a href={`/interviews/schedule?candidate=${candidate.id}`} class="btn btn-primary btn-sm">Schedule Interview</a>}
    </div>
  </div>

  <!-- Score banner — the headline number/recommendation is the LIVE blended
       read (resume + every analyzed interview round, recomputed on every
       page load via buildCandidateSummary), not a frozen resume-upload-time
       snapshot. Skills/Experience/Education stay as resume facts (they
       describe the document itself and don't change), but the number badged
       "AI Score" is the one that should move as the candidate progresses —
       see the narrative sentence below for exactly how it's derived. -->
  <div class="card shadow-lvl-2" style="display:flex;gap:24px;align-items:center;flex-wrap:wrap;padding:20px 24px;margin-bottom:20px;">
    <div style="text-align:center;">
      <div style="font-size:40px;font-weight:700;color:var(--fg);letter-spacing:-2px;font-family:'JetBrains Mono',monospace;line-height:1;">{summary.overallScore}</div>
      <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;margin-top:4px;">AI Score</div>
      {summary.roundsConsidered > 0 && <div style="font-size:10px;color:var(--fg-mute);margin-top:3px;">resume {candidate.score} + {summary.roundsConsidered} interview{summary.roundsConsidered === 1 ? '' : 's'}</div>}
    </div>
    <div style="width:1px;height:48px;background:var(--border);flex-shrink:0;"></div>
    <div class="grid-cols-3" style="flex:1;min-width:200px;gap:20px;">
      <div>
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:4px;">Skills Match</div>
        <div style="font-size:20px;font-weight:600;color:var(--fg);">{candidate.skillsMatch}%</div>
        <div class="progress" style="margin-top:6px;"><div class="progress-bar" style={`width:${candidate.skillsMatch}%`}></div></div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:4px;">Experience</div>
        <div style="font-size:20px;font-weight:600;color:var(--fg);">{candidate.experience} yrs</div>
        <div class="progress" style="margin-top:6px;"><div class="progress-bar" style={`width:${Math.min(candidate.experience / 10 * 100, 100)}%`}></div></div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:4px;">Education</div>
        <div style="font-size:20px;font-weight:600;color:var(--fg);">{candidate.educationMatch}%</div>
        <div class="progress" style="margin-top:6px;"><div class="progress-bar" style={`width:${candidate.educationMatch}%`}></div></div>
      </div>
    </div>
    <div style="width:1px;height:48px;background:var(--border);flex-shrink:0;"></div>
    <div>
      <span class={`badge ${summary.overallLabel === 'Strongly Recommend' ? 'badge-success' : summary.overallLabel === 'Recommend' ? 'badge-info' : summary.overallLabel === 'Consider' ? 'badge-warning' : 'badge-error'}`} style="font-size:13px;padding:4px 12px;">
        {summary.overallLabel}
      </span>
      <div style="font-size:11px;color:var(--fg-mute);margin-top:6px;text-align:center;">AI Recommendation</div>
    </div>
  </div>

  <div class="grid-main-aside" style="--aside-w:300px;">
    <div style="display:flex;flex-direction:column;gap:20px;">
      <!-- Dynamic AI Assessment — recomputed from the resume read plus every
           completed interview's analysis, so it shifts as the candidate
           actually moves through the pipeline rather than freezing at upload. -->
      <div class="card shadow-lvl-2">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          AI Assessment
          <span class={`badge ${verdictBadgeClass}`} style="font-size:10px;text-transform:none;letter-spacing:0;font-family:inherit;">{summary.verdictLabel}</span>
          {summary.roundsConsidered > 0 && <span style="font-size:11px;color:var(--fg-mute);font-weight:400;text-transform:none;letter-spacing:0;font-family:inherit;">· based on resume + {summary.roundsConsidered} completed interview{summary.roundsConsidered === 1 ? '' : 's'}</span>}
        </h2>
        <div style="background:var(--bg-soft);border-radius:6px;padding:16px;border-left:3px solid var(--fg);margin-bottom:16px;">
          <p style="font-size:14px;color:var(--fg-body);line-height:1.6;margin:0;max-height:220px;overflow-y:auto;padding-right:8px;">{summary.narrative}</p>
        </div>

        {summary.roundBreakdown.length > 0 && (
          <div style="margin-bottom:16px;">
            <h3 style="font-size:12px;font-weight:600;color:var(--fg-mute);margin:0 0 10px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Score progression by round</h3>
            <div style="display:flex;flex-direction:column;gap:8px;max-height:260px;overflow-y:auto;padding-right:4px;">
              {summary.roundBreakdown.map(r => (
                <div style="display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:6px;background:var(--bg-soft);border:1px solid var(--border);">
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:13px;font-weight:500;color:var(--fg);display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                      {r.round}
                      <span class={`badge ${r.decision === 'advance' ? 'badge-success' : 'badge-warning'}`} style="font-size:10px;">{r.decision === 'advance' ? 'Advance' : 'Hold'}</span>
                    </div>
                    <div style="font-size:11px;color:var(--fg-mute);margin-top:2px;font-family:'JetBrains Mono',monospace;">
                      {r.date} · Comm {r.commScore} · Tech {r.techScore} · Conf {r.confidenceScore}
                    </div>
                  </div>
                  <div style="text-align:right;flex-shrink:0;">
                    <div style="font-size:18px;font-weight:700;color:var(--fg);font-family:'JetBrains Mono',monospace;line-height:1;">{r.overallScore}</div>
                    <div style={`font-size:11px;margin-top:2px;font-family:'JetBrains Mono',monospace;color:${r.trend === 'up' ? '#10b981' : r.trend === 'down' ? '#ef4444' : 'var(--fg-mute)'};`}>
                      {r.trend === 'first' ? 'baseline' : r.trend === 'flat' ? 'steady' : `${r.trend === 'up' ? '▲' : '▼'} ${Math.abs(r.trendDelta)}`}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="grid-cols-2" style="gap:16px;">
          <div>
            <h3 style="font-size:12px;font-weight:600;color:#10b981;margin:0 0 8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Why move forward</h3>
            {summary.forwardSignals.length ? (
              <ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:6px;">
                {summary.forwardSignals.map(s => <li style="font-size:13px;color:var(--fg-body);line-height:1.4;">{s}</li>)}
              </ul>
            ) : <p style="font-size:13px;color:var(--fg-mute);margin:0;">{summary.verdict === 'rejected' ? 'Not applicable — the process has ended.' : 'No concrete positive signal recorded yet.'}</p>}
          </div>
          <div>
            <h3 style="font-size:12px;font-weight:600;color:#ef4444;margin:0 0 8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Why hold or reject</h3>
            {summary.verdict === 'hired' ? (
              <p style="font-size:13px;color:var(--fg-mute);margin:0;">Not applicable — {candidate.name} was hired; there's no open question left to weigh against.</p>
            ) : summary.concernSignals.length ? (
              <ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:6px;">
                {summary.concernSignals.map(s => <li style="font-size:13px;color:var(--fg-body);line-height:1.4;">{s}</li>)}
              </ul>
            ) : <p style="font-size:13px;color:var(--fg-mute);margin:0;">No concrete concerns recorded yet.</p>}
          </div>
        </div>
      </div>

      <!-- Skills Analysis -->
      {skillsToShow.length > 0 && (
        <div class="card shadow-lvl-2">
          <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Skills Analysis</h2>
          <div style="display:flex;flex-direction:column;gap:14px;max-height:340px;overflow-y:auto;padding-right:8px;">
            {skillsToShow.map((skill: string, i: number) => (
              <div>
                <div style="display:flex;align-items:center;gap:12px;">
                  <div style="width:110px;font-size:13px;color:var(--fg-body);flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title={skill}>{skill}</div>
                  <div class="progress" style="flex:1;"><div class="progress-bar" style={`width:${skillStatus[i].score}%;background:${skillStatus[i].score === 0 ? '#ef4444' : skillStatus[i].score >= 95 ? '#10b981' : 'var(--accent, #6366f1)'};`}></div></div>
                  <div style="font-size:12px;color:var(--fg-mute);width:32px;text-align:right;font-family:'JetBrains Mono',monospace;">{skillStatus[i].score}%</div>
                </div>
                <div style="font-size:11px;color:var(--fg-mute);margin:3px 0 0 122px;">{skillStatus[i].label}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Resume file info -->
      {candidate.resumeName && (
        <div class="card shadow-lvl-2">
          <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 12px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Resume</h2>
          <div style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--bg-soft);border-radius:6px;border:1px solid var(--border);">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;opacity:0.6;"><rect x="3" y="1" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 7h8M6 10h8M6 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:500;color:var(--fg);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{candidate.resumeName}</div>
              <div style="font-size:11px;color:var(--fg-mute);">Uploaded · {candidate.applied}</div>
            </div>
            <a href={`/api/candidates/${candidate.id}/resume`} download={candidate.resumeName} class="btn btn-secondary btn-sm" style="flex-shrink:0;">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:4px;"><path d="M7 1.5v7.5M3.5 6L7 9.5 10.5 6M2 12.5h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Download
            </a>
          </div>
          <button id="reanalyze-btn" class="btn btn-ghost btn-sm" style="width:100%;margin-top:10px;">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" style="margin-right:5px;"><path d="M12.5 7A5.5 5.5 0 1 1 10.5 2.8M12.5 2.5v3h-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Re-analyze resume with the latest analysis engine
          </button>
          <p style="font-size:11px;color:var(--fg-mute);margin:6px 0 0;line-height:1.4;">Re-runs location, experience, skills, and scoring straight from the file on record — useful if the parsed read above looks off.</p>
        </div>
      )}
    </div>

    <!-- Right sidebar -->
    <div style="display:flex;flex-direction:column;gap:16px;">
      {(candidate.email || candidate.phone) && (
        <div class="card shadow-lvl-2">
          <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Contact</h3>
          <div style="display:flex;flex-direction:column;gap:10px;font-size:13px;">
            {candidate.email && <div style="color:var(--fg-body);">{candidate.email}</div>}
            {candidate.phone && <div style="color:var(--fg-body);">{candidate.phone}</div>}
          </div>
        </div>
      )}

      <div class="card shadow-lvl-2">
        <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Application</h3>
        <div style="display:flex;flex-direction:column;gap:10px;font-size:13px;">
          {candidate.jobTitle && <div style="display:flex;justify-content:space-between;"><span style="color:var(--fg-mute);">Job</span><span style="color:var(--fg);font-weight:500;text-align:right;max-width:160px;">{candidate.jobTitle}</span></div>}
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="color:var(--fg-mute);">Stage</span>
            {candidate.rejected ? (
              <span class="badge badge-error">Rejected</span>
            ) : (
              <select id="stage-select" class="select" style="width:140px;height:28px;font-size:12px;" data-current-stage={candidate.currentStage}>
                {validStages.map(s => (
                  <option value={s.key} selected={candidate.currentStage === s.key}>{s.label}</option>
                ))}
              </select>
            )}
          </div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--fg-mute);">Applied</span><span style="color:var(--fg);font-family:'JetBrains Mono',monospace;">{candidate.applied}</span></div>
        </div>
      </div>

      <div class="card shadow-lvl-2">
        <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Actions</h3>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <a href={`/candidates/${candidate.id}/journey`} class="btn btn-primary" style="width:100%;border-radius:6px;">View Journey</a>
          {canScheduleOrReject && <a href={`/interviews/schedule?candidate=${candidate.id}`} class="btn btn-secondary" style="width:100%;border-radius:6px;">Schedule Interview</a>}
          {canScheduleOrReject && <button id="reject-btn" class="btn btn-ghost" style="width:100%;color:#ef4444;">Reject Candidate</button>}
          <button id="delete-btn" class="btn btn-ghost" style="width:100%;color:#ee0000;">Delete Candidate</button>
        </div>
      </div>

      <div class="card shadow-lvl-2">
        <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Notes</h3>
        <textarea id="notes-input" class="input" style="height:100px;padding:10px 12px;resize:vertical;font-size:13px;" placeholder="Add private recruiter notes…">{candidate.notes}</textarea>
        <button id="save-notes" class="btn btn-ghost btn-sm" style="margin-top:8px;width:100%;">Save Note</button>
      </div>
    </div>
  </div>
</AppLayout>

<script define:vars={{ candidateId: candidate.id }}>
  document.getElementById('stage-select')?.addEventListener('change', async (e) => {
    const select = e.target;
    const previousStage = select.dataset.currentStage || '';
    const currentStage = select.value;
    const notes = await window.hvPrompt({
      title: 'Move candidate',
      message: 'Add an optional note about this move (visible on the candidate journey):',
      placeholder: 'e.g. Strong portfolio, moving to next round',
      confirmLabel: 'Move',
    });
    if (notes === null) {
      select.value = previousStage;
      return;
    }
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentStage, notes }),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const err = await res.json().catch(() => ({}));
      window.hvToast(err.error || 'Failed to update stage', 'error');
      select.value = previousStage;
    }
  });

  document.getElementById('reject-btn')?.addEventListener('click', async () => {
    const ok = await window.hvConfirm({
      title: 'Reject candidate',
      message: 'Reject this candidate? This is a terminal action and cannot be undone.',
      confirmLabel: 'Reject',
      destructive: true,
    });
    if (!ok) return;
    const res = await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rejected: true }),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      window.hvToast(err.error || 'Failed to reject candidate', 'error');
    }
    window.location.reload();
  });

  document.getElementById('save-notes')?.addEventListener('click', async () => {
    const notes = document.getElementById('notes-input').value;
    await fetch(`/api/candidates/${candidateId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ notes }),
    });
    const btn = document.getElementById('save-notes');
    btn.textContent = '✓ Saved';
    setTimeout(() => { btn.textContent = 'Save Note'; }, 2000);
  });

  document.getElementById('delete-btn')?.addEventListener('click', async () => {
    const ok = await window.hvConfirm({
      title: 'Delete candidate',
      message: 'Delete this candidate? This cannot be undone.',
      confirmLabel: 'Delete',
      destructive: true,
    });
    if (!ok) return;
    const res = await fetch(`/api/candidates/${candidateId}`, { method: 'DELETE' });
    if (res.ok) window.location.href = '/candidates';
    else window.hvToast('Failed to delete.', 'error');
  });

  document.getElementById('reanalyze-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    btn.disabled = true;
    const original = btn.innerHTML;
    btn.textContent = 'Re-analyzing…';
    try {
      const res = await fetch(`/api/candidates/${candidateId}/reanalyze`, { method: 'POST' });
      if (res.ok) {
        window.hvToast('Resume re-analyzed with the latest engine.', 'success');
        window.location.reload();
      } else {
        const err = await res.json().catch(() => ({}));
        window.hvToast(err.error || 'Failed to re-analyze resume.', 'error');
        btn.disabled = false;
        btn.innerHTML = original;
      }
    } catch {
      window.hvToast('Failed to re-analyze resume.', 'error');
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });
</script>
