---
import "../styles/global.css";

const { error } = Astro.props as { error?: unknown };
const message = error instanceof Error ? error.message : "An unexpected server error occurred.";
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>500 — Server Error · HireVerse AI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:24px;">
    <div style="text-align:center;max-width:480px;">
      <div style="width:56px;height:56px;border-radius:14px;background:var(--error);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
        <svg width="26" height="26" viewBox="0 0 16 16" fill="none">
          <path d="M8 5v3.5M8 11h.01" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="8" cy="8" r="6.5" stroke="#fff" stroke-width="1.6"/>
        </svg>
      </div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--fg-mute);letter-spacing:0.5px;margin-bottom:8px;">ERROR 500</div>
      <h1 style="font-size:28px;font-weight:600;color:var(--fg);letter-spacing:-0.6px;margin-bottom:12px;">Something went wrong</h1>
      <p style="font-size:14px;line-height:1.6;color:var(--fg-body);margin-bottom:8px;">
        We hit an unexpected error while rendering this page. This is usually temporary — try refreshing, or head back to the dashboard.
      </p>
      <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--fg-mute);background:var(--card-bg-soft);border:1px solid var(--border);border-radius:8px;padding:10px 14px;margin-bottom:28px;word-break:break-word;">
        {message}
      </p>
      <div style="display:flex;gap:10px;justify-content:center;">
        <a href="/dashboard" class="btn btn-primary">Back to Dashboard</a>
        <a href="javascript:location.reload()" class="btn btn-secondary">Retry</a>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const saved = localStorage.getItem("hv-theme");
      if (saved === "light") document.documentElement.classList.remove("dark");
      else document.documentElement.classList.add("dark");
    })();
  </script>
</body>
</html>
