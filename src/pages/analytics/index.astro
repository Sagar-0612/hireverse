---
import AppLayout from "../../layouts/AppLayout.astro";
import { connectDB } from "../../db/connection";
import { Candidate } from "../../db/models/Candidate";
import { Job } from "../../db/models/Job";
import { Interview } from "../../db/models/Interview";
import { LearningSignal } from "../../db/models/LearningSignal";
import { bucketForCandidate, type FunnelBucket } from "../../lib/pipeline";
import { summarizeOutcomeSignals } from "../../lib/learningEngine";
import { Types } from "mongoose";

await connectDB();

// --- Filters: job + time range, driven by query params so links/exports are shareable ---
const params = Astro.url.searchParams;
const jobFilter = params.get('job') || '';
const rangeFilter = params.get('range') || 'all';
const fromParam = params.get('from') || '';
const toParam = params.get('to') || '';

const RANGE_PRESETS: Record<string, number> = { '7d': 7, '30d': 30, '90d': 90, '6m': 183, '12m': 365 };
let dateFrom: Date | null = null;
let dateTo: Date | null = null;
if (rangeFilter === 'custom' && (fromParam || toParam)) {
  if (fromParam) dateFrom = new Date(`${fromParam}T00:00:00`);
  if (toParam) dateTo = new Date(`${toParam}T23:59:59`);
} else if (rangeFilter in RANGE_PRESETS) {
  const d = new Date();
  d.setDate(d.getDate() - RANGE_PRESETS[rangeFilter]);
  dateFrom = d;
}

const dateRangeMatch: Record<string, any> = {};
if (dateFrom || dateTo) {
  dateRangeMatch.createdAt = {};
  if (dateFrom) dateRangeMatch.createdAt.$gte = dateFrom;
  if (dateTo) dateRangeMatch.createdAt.$lte = dateTo;
}

const jobObjectId = jobFilter && Types.ObjectId.isValid(jobFilter) ? new Types.ObjectId(jobFilter) : null;
const jobIdMatch: Record<string, any> = jobObjectId ? { jobId: jobObjectId } : {};
const candidateFilter = { ...jobIdMatch, ...dateRangeMatch };

const allJobsForFilter = await Job.find({}, 'title').sort({ title: 1 }).lean();
const selectedJob = jobObjectId ? allJobsForFilter.find(j => j._id.toString() === jobFilter) : null;

const exportParams = new URLSearchParams();
if (jobFilter) exportParams.set('job', jobFilter);
if (rangeFilter !== 'all') exportParams.set('range', rangeFilter);
if (fromParam) exportParams.set('from', fromParam);
if (toParam) exportParams.set('to', toParam);
const exportQuery = exportParams.toString();
const filtersActive = jobFilter !== '' || rangeFilter !== 'all';

const [totalJobsCount, totalInterviews] = await Promise.all([
  Job.countDocuments({ status: { $in: ['active', 'interviewing'] } }),
  Interview.countDocuments({ ...jobIdMatch, ...dateRangeMatch }),
]);

// Pull every candidate with its parent job's pipeline so we can bucket by
// relative position in *that job's own* pipeline — the only cross-job-safe way
// to build a funnel when each job defines totally different stages.
const allCandidates = await Candidate.find(candidateFilter, 'jobId currentStage rejected rejectedAt stageHistory createdAt updatedAt')
  .populate('jobId', 'pipeline title')
  .lean();

const hiredCandidates: typeof allCandidates = [];
const bucketByCandidate = new Map<string, FunnelBucket>();
for (const c of allCandidates) {
  const pipeline = (c.jobId as any)?.pipeline || [];
  const bucket = bucketForCandidate(c, pipeline);
  bucketByCandidate.set(c._id.toString(), bucket);
  if (bucket === 'Hired') hiredCandidates.push(c);
}

const totalCandidates = allCandidates.length;
const hiredCount = hiredCandidates.length;
const conversionRate = totalCandidates ? ((hiredCount / totalCandidates) * 100).toFixed(1) : '0.0';

// Monthly trends (last 6 months) — applications from createdAt, hires from each
// hired candidate's last real stageHistory transition (or updatedAt as fallback).
const now = new Date();
const sixMonthsAgo = new Date(now.getFullYear(), now.getMonth() - 5, 1);
const monthlyRaw = await Candidate.aggregate([
  { $match: { createdAt: { $gte: sixMonthsAgo }, ...jobIdMatch } },
  { $group: { _id: { year: { $year: '$createdAt' }, month: { $month: '$createdAt' } }, count: { $sum: 1 } } },
  { $sort: { '_id.year': 1, '_id.month': 1 } },
]);
const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

const hiredByMonth = new Map<string, number>();
for (const c of hiredCandidates) {
  const hist = c.stageHistory || [];
  const at = new Date(hist.length ? hist[hist.length - 1].movedAt : c.updatedAt);
  if (at < sixMonthsAgo) continue;
  const k = `${at.getFullYear()}-${at.getMonth() + 1}`;
  hiredByMonth.set(k, (hiredByMonth.get(k) || 0) + 1);
}

const monthlyTrends = [];
for (let i = 5; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const yr = d.getFullYear(); const mo = d.getMonth() + 1;
  const apps = monthlyRaw.find((x: any) => x._id.year === yr && x._id.month === mo)?.count || 0;
  const hires = hiredByMonth.get(`${yr}-${mo}`) || 0;
  monthlyTrends.push({ month: monthNames[mo - 1], applications: apps, hires });
}

// Top jobs by candidates
const topJobsRaw = await Candidate.aggregate([
  { $match: candidateFilter },
  { $group: { _id: '$jobId', count: { $sum: 1 } } },
  { $sort: { count: -1 } },
  { $limit: jobObjectId ? 1 : 5 },
  { $lookup: { from: 'jobs', localField: '_id', foreignField: '_id', as: 'job' } },
  { $unwind: '$job' },
]);

// Avg interview score
const scoreAgg = await Interview.aggregate([
  { $match: { status: 'completed', techScore: { $gt: 0 }, ...jobIdMatch, ...dateRangeMatch } },
  { $group: { _id: null, avg: { $avg: { $avg: ['$techScore', '$commScore', '$confidenceScore'] } } } },
]);
const avgScore = scoreAgg.length ? Math.round(scoreAgg[0].avg) : 0;

// Conversion by job — for each of the top jobs by applicant volume, what
// share of applicants are CURRENTLY hired. This is a per-job PERFORMANCE
// metric (does this role's pipeline actually convert?), distinct from the
// Dashboard's "Hiring Funnel" which shows the live, all-jobs snapshot of
// where candidates sit right now.
const jobConversion = topJobsRaw.map(r => {
  const jobId = r._id.toString();
  const jobCandidateIds = allCandidates.filter(c => (c.jobId as any)?._id?.toString() === jobId).map(c => c._id.toString());
  const hired = jobCandidateIds.filter(id => bucketByCandidate.get(id) === 'Hired').length;
  const rejected = jobCandidateIds.filter(id => bucketByCandidate.get(id) === 'Rejected').length;
  return {
    title: r.job.title as string,
    id: jobId,
    status: r.job.status as string,
    total: jobCandidateIds.length,
    hired,
    rejected,
    conversionPct: jobCandidateIds.length ? Math.round((hired / jobCandidateIds.length) * 100) : 0,
  };
});

// Score calibration overview — condensed cross-job summary of the adaptive
// learning layer (src/lib/learningEngine.ts): does our resume scoring rubric
// actually correlate with real pipeline outcomes? Full per-job breakdown
// lives on the Platform Intelligence page; this card is the "is our scoring
// trustworthy" headline for the performance-review audience.
const outcomeSignals = await LearningSignal.find({ type: 'stage-outcome', ...(jobFilter ? { jobId: jobFilter } : {}), ...dateRangeMatch }, 'jobId score outcome').lean();
const jobIdsForCalibration = [...new Set(outcomeSignals.map(s => s.jobId))];
const jobsForCalibration = jobIdsForCalibration.length ? await Job.find({ _id: { $in: jobIdsForCalibration } }, 'title').lean() : [];
const jobTitlesForCalibration: Record<string, string> = {};
for (const j of jobsForCalibration) jobTitlesForCalibration[j._id.toString()] = j.title;
const calibration = summarizeOutcomeSignals(
  outcomeSignals.map(s => ({ jobId: s.jobId, score: s.score, outcome: s.outcome })),
  jobTitlesForCalibration
);
const totalSignals = outcomeSignals.length;
const advancedOrHiredSignals = outcomeSignals.filter(s => s.outcome === 'advanced' || s.outcome === 'hired').length;
const overallAdvanceRate = totalSignals ? Math.round((advancedOrHiredSignals / totalSignals) * 100) : 0;
---

<AppLayout title="Analytics" activeNav="analytics">
  <div style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <h1 style="font-size:24px;font-weight:600;color:var(--fg);letter-spacing:-0.5px;margin:0 0 4px;">Analytics</h1>
        <p style="font-size:14px;color:var(--fg-mute);margin:0;">
          Hiring performance and pipeline insights.
          {filtersActive && (
            <span style="margin-left:6px;">
              · Showing {selectedJob ? <strong style="color:var(--fg-body);">{selectedJob.title}</strong> : 'all jobs'}
              {rangeFilter !== 'all' && (
                <> · {rangeFilter === 'custom'
                  ? `${fromParam || 'earliest'} → ${toParam || 'today'}`
                  : { '7d': 'last 7 days', '30d': 'last 30 days', '90d': 'last 90 days', '6m': 'last 6 months', '12m': 'last 12 months' }[rangeFilter]}</>
              )}
            </span>
          )}
        </p>
      </div>
    </div>
  </div>

  <form method="get" id="analytics-filter-form" class="card shadow-lvl-2" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:24px;padding:14px 16px;">
    <select name="job" class="select" style="width:220px;">
      <option value="">All Jobs</option>
      {allJobsForFilter.map(j => (
        <option value={j._id.toString()} selected={jobFilter === j._id.toString()}>{j.title}</option>
      ))}
    </select>
    <select name="range" id="range-select" class="select" style="width:160px;">
      <option value="all" selected={rangeFilter === 'all'}>All time</option>
      <option value="7d" selected={rangeFilter === '7d'}>Last 7 days</option>
      <option value="30d" selected={rangeFilter === '30d'}>Last 30 days</option>
      <option value="90d" selected={rangeFilter === '90d'}>Last 90 days</option>
      <option value="6m" selected={rangeFilter === '6m'}>Last 6 months</option>
      <option value="12m" selected={rangeFilter === '12m'}>Last 12 months</option>
      <option value="custom" selected={rangeFilter === 'custom'}>Custom range</option>
    </select>
    <input type="date" name="from" id="from-input" class="input" style={`width:140px;${rangeFilter === 'custom' ? '' : 'display:none;'}`} value={fromParam} />
    <input type="date" name="to" id="to-input" class="input" style={`width:140px;${rangeFilter === 'custom' ? '' : 'display:none;'}`} value={toParam} />
    <button type="submit" class="btn btn-secondary btn-sm">Apply</button>
    {filtersActive && <a href="/analytics" class="btn btn-ghost btn-sm">Reset</a>}
    <a href={`/api/analytics/export.csv${exportQuery ? `?${exportQuery}` : ''}`} class="btn btn-primary btn-sm" style="margin-left:auto;">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="margin-right:4px;vertical-align:-2px;"><path d="M6.5 1v7M3.5 5.5l3 3 3-3M2 11h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Export CSV
    </a>
  </form>

  <script>
    const rangeSelect = document.getElementById('range-select') as HTMLSelectElement;
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    rangeSelect?.addEventListener('change', () => {
      const isCustom = rangeSelect.value === 'custom';
      fromInput.style.display = isCustom ? '' : 'none';
      toInput.style.display = isCustom ? '' : 'none';
    });
  </script>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:28px;">
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Total Applications</div>
      <div class="stat-value">{totalCandidates}</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Active Jobs</div>
      <div class="stat-value">{totalJobsCount}</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Hiring Conversion</div>
      <div class="stat-value">{conversionRate}%</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Total Interviews</div>
      <div class="stat-value">{totalInterviews}</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Avg Interview Score</div>
      <div class="stat-value">{avgScore > 0 ? avgScore : '—'}</div>
    </div>
  </div>

  <div class="grid-cols-2" style="margin-bottom:20px;">
    <div class="card shadow-lvl-2">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
        <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Conversion by Job</h2>
        <span class="badge badge-neutral" style="font-size:11px;font-family:'JetBrains Mono',monospace;">{jobObjectId ? 'Selected job' : 'Top 5 by volume'}</span>
      </div>
      <p style="font-size:12px;color:var(--fg-mute);margin:0 0 16px;">Of everyone who applied to each role, what share is currently hired — a performance read, not a live snapshot.</p>
      {jobConversion.length === 0 ? (
        <div class="empty-state" style="padding:32px 0;">No candidates yet</div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:12px;">
          {jobConversion.map(jc => (
            <div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                <a href={`/jobs/${jc.id}`} style="font-size:13px;font-weight:500;color:var(--fg);text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{jc.title}</a>
                <span style="font-size:12px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;flex-shrink:0;">{jc.hired}/{jc.total} hired · {jc.conversionPct}%</span>
              </div>
              <div class="progress"><div class="progress-bar" style={`width:${Math.max(jc.conversionPct, jc.hired > 0 ? 4 : 0)}%;background:${jc.conversionPct >= 20 ? '#10b981' : jc.conversionPct >= 5 ? '#f59e0b' : '#6b7280'};`}></div></div>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="card shadow-lvl-2">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Monthly Trends</h2>
        <div style="display:flex;gap:12px;font-size:12px;color:var(--fg-mute);">
          <span style="display:flex;align-items:center;gap:4px;"><span style="width:8px;height:8px;border-radius:2px;background:var(--fg);display:inline-block;opacity:0.75;"></span>Applications</span>
          <span style="display:flex;align-items:center;gap:4px;"><span style="width:8px;height:8px;border-radius:2px;background:#22c55e;display:inline-block;opacity:0.85;"></span>Hires</span>
        </div>
      </div>
      {monthlyTrends.some(m => m.applications > 0 || m.hires > 0) ? (
        <div style="display:flex;gap:8px;align-items:flex-end;height:140px;">
          {monthlyTrends.map(m => {
            const maxVal = Math.max(...monthlyTrends.map(x => Math.max(x.applications, x.hires)), 1);
            const appH = Math.round((m.applications / maxVal) * 120);
            const hireH = Math.round((m.hires / maxVal) * 120);
            return (
              <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;">
                <div style="width:100%;display:flex;gap:2px;align-items:flex-end;height:124px;">
                  <div style={`flex:1;height:${Math.max(appH,m.applications > 0 ? 4 : 0)}px;background:var(--fg);border-radius:3px 3px 0 0;opacity:0.75;`}></div>
                  <div style={`flex:1;height:${Math.max(hireH,m.hires > 0 ? 4 : 0)}px;background:#22c55e;border-radius:3px 3px 0 0;opacity:0.85;`}></div>
                </div>
                <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;">{m.month}</div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="empty-state" style="padding:32px 0;">No data yet</div>
      )}
    </div>
  </div>

  <div class="grid-cols-2" style="margin-bottom:20px;">
    <div class="card shadow-lvl-2">
      <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0 0 20px;">{jobObjectId ? 'Selected Job' : 'Top Jobs by Applications'}</h2>
      {topJobsRaw.length > 0 ? (
        <div class="table-container">
          <table>
            <thead>
              <tr><th>Job</th><th>Department</th><th>Applicants</th><th>Status</th></tr>
            </thead>
            <tbody>
              {topJobsRaw.map(r => (
                <tr>
                  <td>
                    <a href={`/jobs/${r.job._id.toString()}`} style="font-size:13px;font-weight:500;color:var(--fg);text-decoration:none;">{r.job.title}</a>
                  </td>
                  <td style="font-size:12px;color:var(--fg-mute);">{r.job.department}</td>
                  <td style="font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;color:var(--fg);">{r.count}</td>
                  <td><span class={`badge ${r.job.status === 'active' ? 'badge-success' : 'badge-info'}`}>{r.job.status}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="empty-state" style="padding:32px 0;">No candidates yet</div>
      )}
    </div>

    <div class="card shadow-lvl-2">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
        <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Score Calibration</h2>
        <a href="/intelligence" class="btn btn-ghost btn-sm">Full breakdown →</a>
      </div>
      <p style="font-size:12px;color:var(--fg-mute);margin:0 0 16px;">Does our resume scoring rubric actually predict who advances? Read-only — never changes how any candidate is scored.</p>
      {totalSignals === 0 ? (
        <div class="empty-state" style="padding:32px 0;">No pipeline outcomes recorded yet — this fills in as candidates are advanced, hired, or rejected.</div>
      ) : (
        <div>
          <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:16px;">
            <div style={`font-size:32px;font-weight:700;font-family:'JetBrains Mono',monospace;color:${overallAdvanceRate >= 60 ? '#10b981' : overallAdvanceRate >= 30 ? '#f59e0b' : '#ef4444'};`}>{overallAdvanceRate}%</div>
            <div style="font-size:12px;color:var(--fg-mute);">of {totalSignals} recorded outcome{totalSignals === 1 ? '' : 's'} were advances or hires</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {calibration.slice(0, 3).map(insight => (
              <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);">
                <span style="font-size:13px;color:var(--fg-body);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{insight.jobTitle}</span>
                <span style="font-size:12px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;flex-shrink:0;">{insight.totalSignals} signal{insight.totalSignals === 1 ? '' : 's'}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</AppLayout>
