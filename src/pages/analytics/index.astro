---
import AppLayout from "../../layouts/AppLayout.astro";
import { connectDB } from "../../db/connection";
import { Candidate } from "../../db/models/Candidate";
import { Job } from "../../db/models/Job";
import { Interview } from "../../db/models/Interview";

await connectDB();

const [totalCandidates, totalJobs, totalInterviews] = await Promise.all([
  Candidate.countDocuments(),
  Job.countDocuments({ status: { $in: ['active', 'interviewing'] } }),
  Interview.countDocuments(),
]);

// Funnel
const funnelRaw = await Candidate.aggregate([
  { $group: { _id: '$status', count: { $sum: 1 } } },
]);
const statusOrder = ['applied','screening','shortlisted','interview','offered','hired'];
const funnelMap = Object.fromEntries(funnelRaw.map(r => [r._id, r.count]));
const maxCount = Math.max(...statusOrder.map(s => funnelMap[s] || 0), 1);
const funnelData = statusOrder.map(s => ({
  stage: s.charAt(0).toUpperCase() + s.slice(1),
  count: funnelMap[s] || 0,
  pct: Math.round(((funnelMap[s] || 0) / maxCount) * 100),
}));

// Monthly trends (last 6 months)
const now = new Date();
const sixMonthsAgo = new Date(now.getFullYear(), now.getMonth() - 5, 1);
const monthlyRaw = await Candidate.aggregate([
  { $match: { createdAt: { $gte: sixMonthsAgo } } },
  { $group: { _id: { year: { $year: '$createdAt' }, month: { $month: '$createdAt' } }, count: { $sum: 1 } } },
  { $sort: { '_id.year': 1, '_id.month': 1 } },
]);
const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const monthlyTrends = monthlyRaw.map(r => ({
  month: monthNames[r._id.month - 1],
  applications: r.count,
  hires: Math.floor(r.count * 0.05),
}));

// Top jobs by candidates
const topJobsRaw = await Candidate.aggregate([
  { $group: { _id: '$jobId', count: { $sum: 1 } } },
  { $sort: { count: -1 } },
  { $limit: 5 },
  { $lookup: { from: 'jobs', localField: '_id', foreignField: '_id', as: 'job' } },
  { $unwind: '$job' },
]);

// Avg interview score
const scoreAgg = await Interview.aggregate([
  { $match: { status: 'completed', techScore: { $gt: 0 } } },
  { $group: { _id: null, avg: { $avg: { $avg: ['$techScore', '$commScore', '$confidenceScore'] } } } },
]);
const avgScore = scoreAgg.length ? Math.round(scoreAgg[0].avg) : 0;

const hired = funnelMap['hired'] || 0;
const conversionRate = totalCandidates ? ((hired / totalCandidates) * 100).toFixed(1) : '0.0';
---

<AppLayout title="Analytics" activeNav="analytics">
  <div style="margin-bottom:28px;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <h1 style="font-size:24px;font-weight:600;color:var(--fg);letter-spacing:-0.5px;margin:0 0 4px;">Analytics</h1>
        <p style="font-size:14px;color:var(--fg-mute);margin:0;">Hiring performance and pipeline insights.</p>
      </div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:28px;">
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Total Applications</div>
      <div class="stat-value">{totalCandidates}</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Active Jobs</div>
      <div class="stat-value">{totalJobs}</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Hiring Conversion</div>
      <div class="stat-value">{conversionRate}%</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Total Interviews</div>
      <div class="stat-value">{totalInterviews}</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Avg Interview Score</div>
      <div class="stat-value">{avgScore > 0 ? avgScore : '—'}</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    <div class="card shadow-lvl-2">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Applicant Funnel</h2>
        <span class="badge badge-neutral" style="font-size:11px;font-family:'JetBrains Mono',monospace;">All Jobs</span>
      </div>
      {funnelData.map(row => (
        <div class="funnel-row">
          <span class="funnel-label">{row.stage}</span>
          <div class="funnel-track"><div class="funnel-fill" style={`width:${row.pct}%`}></div></div>
          <span class="funnel-count">{row.count}</span>
        </div>
      ))}
    </div>

    <div class="card shadow-lvl-2">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Monthly Trends</h2>
        <div style="display:flex;gap:12px;font-size:12px;color:var(--fg-mute);">
          <span style="display:flex;align-items:center;gap:4px;"><span style="width:8px;height:8px;border-radius:2px;background:var(--fg);display:inline-block;opacity:0.75;"></span>Applications</span>
        </div>
      </div>
      {monthlyTrends.length > 0 ? (
        <div style="display:flex;gap:8px;align-items:flex-end;height:140px;">
          {monthlyTrends.map(m => {
            const maxApps = Math.max(...monthlyTrends.map(x => x.applications), 1);
            const appH = Math.round((m.applications / maxApps) * 120);
            return (
              <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;">
                <div style="width:100%;display:flex;gap:2px;align-items:flex-end;height:124px;">
                  <div style={`flex:1;height:${Math.max(appH,4)}px;background:var(--fg);border-radius:3px 3px 0 0;opacity:0.75;`}></div>
                </div>
                <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;">{m.month}</div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="empty-state" style="padding:32px 0;">No data yet</div>
      )}
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="card shadow-lvl-2">
      <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0 0 20px;">Top Jobs by Applications</h2>
      {topJobsRaw.length > 0 ? (
        <div class="table-container">
          <table>
            <thead>
              <tr><th>Job</th><th>Department</th><th>Applicants</th><th>Status</th></tr>
            </thead>
            <tbody>
              {topJobsRaw.map(r => (
                <tr>
                  <td>
                    <a href={`/jobs/${r.job._id.toString()}`} style="font-size:13px;font-weight:500;color:var(--fg);text-decoration:none;">{r.job.title}</a>
                  </td>
                  <td style="font-size:12px;color:var(--fg-mute);">{r.job.department}</td>
                  <td style="font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;color:var(--fg);">{r.count}</td>
                  <td><span class={`badge ${r.job.status === 'active' ? 'badge-success' : 'badge-info'}`}>{r.job.status}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="empty-state" style="padding:32px 0;">No candidates yet</div>
      )}
    </div>

    <div class="card shadow-lvl-2">
      <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0 0 20px;">Pipeline Summary</h2>
      <div style="display:flex;flex-direction:column;gap:10px;">
        {funnelData.map(row => (
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);">
            <span style="font-size:13px;color:var(--fg-body);">{row.stage}</span>
            <span style="font-size:15px;font-weight:600;color:var(--fg);font-family:'JetBrains Mono',monospace;">{row.count}</span>
          </div>
        ))}
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;">
          <span style="font-size:13px;color:var(--fg-body);">Rejected</span>
          <span style="font-size:15px;font-weight:600;color:var(--fg);font-family:'JetBrains Mono',monospace;">{funnelMap['rejected'] || 0}</span>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
