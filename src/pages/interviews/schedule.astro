---
import AppLayout from "../../layouts/AppLayout.astro";
import { connectDB } from "../../db/connection";
import { Candidate } from "../../db/models/Candidate";
import { Team } from "../../db/models/Team";
import { sortedPipeline, bucketForCandidate } from "../../lib/pipeline";

await connectDB();
const rawCandidates = await Candidate.find({ rejected: { $ne: true } })
  .populate('jobId', 'title pipeline')
  .lean();

// Only candidates still moving through a pipeline (not yet at the final/"hired"
// stage and not rejected) are schedulable for further rounds.
const candidates = rawCandidates
  .filter(c => bucketForCandidate(c, (c.jobId as any)?.pipeline || []) !== 'Hired')
  .map(c => {
    const pipeline = sortedPipeline((c.jobId as any)?.pipeline || []);
    return {
      id: c._id.toString(),
      name: c.name,
      jobTitle: (c.jobId as any)?.title || '',
      jobId: (c.jobId as any)?._id?.toString() || '',
      currentStage: c.currentStage,
      stages: pipeline.map(s => ({ key: s.key, label: s.label })),
    };
  });

const teamMembers = await Team.find({ status: 'active' }).lean();

// Pre-select from query param (e.g., /interviews/schedule?candidate=<id>)
const preselected = Astro.url.searchParams.get('candidate') || '';
const today = new Date().toISOString().split('T')[0];
---

<AppLayout title="Schedule Interview" activeNav="interviews">
  <div style="max-width:640px;">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;">
      <a href="/interviews" class="btn btn-ghost btn-sm" style="padding:0;width:28px;height:28px;border-radius:6px;border:1px solid var(--border);">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div>
        <h1 style="font-size:22px;font-weight:600;color:var(--fg);letter-spacing:-0.4px;margin:0;">Schedule Interview</h1>
        <p style="font-size:13px;color:var(--fg-mute);margin:4px 0 0;">Set up a new interview session for a candidate.</p>
      </div>
    </div>

    <div id="error-banner" style="display:none;background:var(--bg-soft);border:1px solid #ee0000;border-radius:6px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#ee0000;"></div>

    {candidates.length === 0 ? (
      <div class="card shadow-lvl-2 empty-state" style="padding:32px;">
        <div style="font-size:15px;font-weight:500;color:var(--fg);margin-bottom:4px;">No schedulable candidates</div>
        <div style="font-size:13px;">Every candidate is either hired or rejected — upload resumes or move someone forward in their pipeline first.</div>
      </div>
    ) : (
    <form id="schedule-form" style="display:flex;flex-direction:column;gap:20px;">
      <div class="card shadow-lvl-2">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Candidate & Stage</h2>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div>
            <label style="font-size:13px;font-weight:500;color:var(--fg);display:block;margin-bottom:6px;">Candidate <span style="color:#ee0000;">*</span></label>
            <select id="candidate-select" name="candidateId" class="select" required>
              <option value="">Select candidate…</option>
              {candidates.map(c => (
                <option
                  value={c.id}
                  selected={c.id === preselected}
                  data-stages={JSON.stringify(c.stages)}
                  data-current-stage={c.currentStage}
                >{c.name}{c.jobTitle ? ` — ${c.jobTitle}` : ''}</option>
              ))}
            </select>
          </div>
          <div>
            <label style="font-size:13px;font-weight:500;color:var(--fg);display:block;margin-bottom:6px;">Pipeline Stage / Round <span style="color:#ee0000;">*</span></label>
            <select id="stage-select" name="pipelineStage" class="select" required disabled>
              <option value="">Select a candidate first…</option>
            </select>
            <p style="font-size:12px;color:var(--fg-mute);margin:6px 0 0;">Scheduling a round for a stage ahead of the candidate's current one will automatically advance them there.</p>
          </div>
          <input type="hidden" name="round" id="round-input" />
        </div>
      </div>

      <div class="card shadow-lvl-2">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Date & Time</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <label style="font-size:13px;font-weight:500;color:var(--fg);display:block;margin-bottom:6px;">Date <span style="color:#ee0000;">*</span></label>
            <input type="date" name="date" class="input" required style="height:36px;" min={today} />
          </div>
          <div>
            <label style="font-size:13px;font-weight:500;color:var(--fg);display:block;margin-bottom:6px;">Time <span style="color:#ee0000;">*</span></label>
            <input type="time" name="time" class="input" required style="height:36px;" />
          </div>
          <div>
            <label style="font-size:13px;font-weight:500;color:var(--fg);display:block;margin-bottom:6px;">Duration</label>
            <select name="duration" class="select">
              <option value="30">30 minutes</option>
              <option value="45">45 minutes</option>
              <option value="60" selected>60 minutes</option>
              <option value="90">90 minutes</option>
              <option value="120">2 hours</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px;font-weight:500;color:var(--fg);display:block;margin-bottom:6px;">Format</label>
            <select name="format" class="select">
              <option value="Video Call">Video Call</option>
              <option value="Phone">Phone</option>
              <option value="On-site">On-site</option>
            </select>
          </div>
        </div>
      </div>

      <div class="card shadow-lvl-2">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Interviewer</h2>
        <select name="interviewer" class="select" required>
          <option value="">Assign interviewer…</option>
          {teamMembers.map(t => (
            <option value={t.name}>{t.name} — {t.role}</option>
          ))}
        </select>
      </div>

      <div class="card shadow-lvl-2">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Notes (Optional)</h2>
        <textarea name="notes" class="input" style="height:100px;padding:10px 12px;resize:vertical;" placeholder="Focus areas, topics to cover, or context for the interviewer…"></textarea>
      </div>

      <div style="display:flex;gap:10px;justify-content:flex-end;padding-bottom:32px;">
        <a href="/interviews" class="btn btn-secondary">Cancel</a>
        <button type="submit" id="submit-btn" class="btn btn-primary">Schedule Interview</button>
      </div>
    </form>
    )}
  </div>
</AppLayout>

<script define:vars={{ preselected }}>
  const candidateSelect = document.getElementById('candidate-select');
  const stageSelect = document.getElementById('stage-select');
  const roundInput = document.getElementById('round-input');

  function populateStages() {
    const opt = candidateSelect?.options[candidateSelect.selectedIndex];
    const stagesJson = opt?.dataset.stages;
    const currentStage = opt?.dataset.currentStage || '';
    if (!stagesJson) {
      stageSelect.innerHTML = '<option value="">Select a candidate first…</option>';
      stageSelect.disabled = true;
      roundInput.value = '';
      return;
    }
    const stages = JSON.parse(stagesJson);
    stageSelect.innerHTML = stages.map(s =>
      `<option value="${s.key}" ${s.key === currentStage ? 'selected' : ''}>${s.label}</option>`
    ).join('');
    stageSelect.disabled = stages.length === 0;
    syncRoundFromStage();
  }

  function syncRoundFromStage() {
    const opt = stageSelect.options[stageSelect.selectedIndex];
    roundInput.value = opt ? opt.textContent : '';
  }

  candidateSelect?.addEventListener('change', populateStages);
  stageSelect?.addEventListener('change', syncRoundFromStage);
  if (candidateSelect?.value) populateStages();

  document.getElementById('schedule-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById('submit-btn');
    const errorBanner = document.getElementById('error-banner');
    btn.disabled = true;
    btn.textContent = 'Scheduling…';
    errorBanner.style.display = 'none';

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch('/api/interviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        const result = await res.json();
        window.location.href = `/interviews/${result.id}`;
      } else {
        const err = await res.json();
        errorBanner.textContent = err.error || 'Failed to schedule interview.';
        errorBanner.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Schedule Interview';
      }
    } catch {
      errorBanner.textContent = 'Network error. Please try again.';
      errorBanner.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Schedule Interview';
    }
  });
</script>
