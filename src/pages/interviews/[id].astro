---
import AppLayout from "../../layouts/AppLayout.astro";
import { connectDB } from "../../db/connection";
import { Interview } from "../../db/models/Interview";
import { Candidate } from "../../db/models/Candidate";
import { Assessment } from "../../db/models/Assessment";
import { Types } from "mongoose";
import { findStage, sortedPipeline, hasUpcomingInterviewStage, hasUpcomingAssessmentStage } from "../../lib/pipeline";
import { scoreColorHex } from "../../lib/scoreColor";
import { generateInterviewGuide, type PriorRoundSummary } from "../../lib/interviewGuide";

const { id } = Astro.params;
if (!id || !Types.ObjectId.isValid(id)) return Astro.redirect('/interviews');

await connectDB();
const raw = await Interview.findById(id)
  .populate('candidateId', 'name rejected')
  .populate('jobId', 'title pipeline requiredSkills niceToHaveSkills education level responsibilities')
  .lean();
if (!raw) return Astro.redirect('/interviews');

const job = raw.jobId as any;
const stage = findStage(job?.pipeline || [], raw.pipelineStage);

const interview = {
  ...raw,
  id: raw._id.toString(),
  candidateName: (raw.candidateId as any)?.name || 'Unknown',
  candidateId: (raw.candidateId as any)?._id?.toString() || '',
  candidateRejected: !!(raw.candidateId as any)?.rejected,
  jobTitle: job?.title || '',
  jobId: job?._id?.toString() || '',
  stageLabel: stage?.label || '',
  stageColor: stage?.color || '#6b7280',
};

const isCompleted = interview.status === 'completed';
const needsAnalysis = isCompleted && !interview.analysis;

// Determine what action makes sense for "next step" based on the candidate's
// remaining pipeline — avoid offering "Schedule Interview" when the next stage
// is actually a coding test, and vice versa.
const candidateDoc = !interview.candidateRejected
  ? await Candidate.findById(interview.candidateId, 'currentStage rejected skillGaps score skillsMatch educationMatch experience recommendation').lean()
  : null;
const candidatePipeline = sortedPipeline(job?.pipeline || []);
const nextCanScheduleInterview = candidateDoc
  ? !candidateDoc.rejected && hasUpcomingInterviewStage(candidatePipeline, candidateDoc.currentStage)
  : false;
const nextCanScheduleAssessment = candidateDoc
  ? !candidateDoc.rejected && hasUpcomingAssessmentStage(candidatePipeline, candidateDoc.currentStage)
  : false;

// Build a gap-focused, accumulating interview guide for upcoming/in-progress
// interviews — pulls in this candidate's resume skill gaps plus concerns
// raised in any prior completed interviews/assessments so each new round
// picks up where the last one left off.
let guideSteps: { title: string; detail: string; questions?: string[] }[] = [];
if (!isCompleted) {
  const [priorInterviews, priorAssessments] = await Promise.all([
    Interview.find({
      candidateId: interview.candidateId,
      _id: { $ne: interview.id },
      status: 'completed',
      analysis: { $ne: null },
    }, 'round analysis').lean(),
    Assessment.find({
      candidateId: interview.candidateId,
      status: 'evaluated',
      analysis: { $ne: null },
    }, 'round analysis').lean(),
  ]);

  const priorRounds: PriorRoundSummary[] = [
    ...priorInterviews.map((iv: any) => ({ round: iv.round, type: 'interview' as const, concerns: iv.analysis?.concerns || [] })),
    ...priorAssessments.map((a: any) => ({ round: a.round, type: 'assessment' as const, concerns: a.analysis?.concerns || [] })),
  ].filter(r => r.concerns.length > 0);

  guideSteps = generateInterviewGuide({
    jobLevel: job?.level || '',
    jobEducation: job?.education || '',
    skillGaps: candidateDoc?.skillGaps || [],
    educationMatch: candidateDoc?.educationMatch ?? 100,
    experience: candidateDoc?.experience ?? 0,
    priorRounds,
    jobResponsibilities: job?.responsibilities || '',
  });
}
---

<AppLayout title={`${interview.candidateName} · Interview`} activeNav="interviews">
  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:28px;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:12px;">
      <a href="/interviews" class="btn btn-ghost btn-sm" style="padding:0;width:28px;height:28px;border-radius:6px;border:1px solid var(--border);">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div>
        <h1 style="font-size:22px;font-weight:600;color:var(--fg);letter-spacing:-0.4px;margin:0;">Interview Details</h1>
        <p style="font-size:13px;color:var(--fg-mute);margin:4px 0 0;">{interview.candidateName} · {interview.round}</p>
      </div>
    </div>
    {!isCompleted && (
      <button id="complete-btn" class="btn btn-primary btn-sm">Mark as Completed</button>
    )}
    {needsAnalysis && (
      <button id="add-feedback-btn-top" class="btn btn-primary btn-sm">Add Feedback &amp; Analyze</button>
    )}
  </div>

  <div class="card shadow-lvl-2" style="margin-bottom:20px;display:flex;gap:24px;flex-wrap:wrap;align-items:center;padding:20px 24px;">
    <div class="avatar" style="width:44px;height:44px;font-size:16px;">{interview.candidateName.split(' ').map((n: string) => n[0]).join('')}</div>
    <div style="flex:1;min-width:0;">
      <div style="font-size:16px;font-weight:600;color:var(--fg);">{interview.candidateName}</div>
      <div style="font-size:13px;color:var(--fg-body);display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        {interview.jobTitle} · {interview.round}
        {interview.stageLabel && <span class="badge" style={`font-size:10px;background:${interview.stageColor}22;color:${interview.stageColor};border:1px solid ${interview.stageColor}55;`}>{interview.stageLabel}</span>}
      </div>
    </div>
    <div style="display:flex;gap:24px;flex-wrap:wrap;">
      <div style="text-align:center;">
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;margin-bottom:4px;">Date</div>
        <div style="font-size:14px;font-weight:500;color:var(--fg);font-family:'JetBrains Mono',monospace;">{interview.date}</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;margin-bottom:4px;">Time</div>
        <div style="font-size:14px;font-weight:500;color:var(--fg);">{interview.time}</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;margin-bottom:4px;">Duration</div>
        <div style="font-size:14px;font-weight:500;color:var(--fg);">{interview.duration} min</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;margin-bottom:4px;">Interviewer</div>
        <div style="font-size:14px;font-weight:500;color:var(--fg);">{interview.interviewer}</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:11px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;text-transform:uppercase;margin-bottom:4px;">Format</div>
        <div style="font-size:14px;font-weight:500;color:var(--fg);">{interview.format}</div>
      </div>
    </div>
    <span class={`badge ${isCompleted ? 'badge-success' : interview.status === 'cancelled' ? 'badge-error' : 'badge-info'}`} style="font-size:13px;padding:4px 12px;">{interview.status}</span>
  </div>

  {isCompleted ? (
    <div>
      <div class="grid-cols-3" style="margin-bottom:20px;">
        <div class="stat-card shadow-lvl-2" style="text-align:center;">
          <div class="stat-label">Communication</div>
          <div class="stat-value" style={`color:${scoreColorHex(interview.commScore)};`}>{interview.commScore}</div>
          <div class="progress" style="margin-top:8px;"><div class="progress-bar" style={`width:${interview.commScore}%;background:${scoreColorHex(interview.commScore)};`}></div></div>
        </div>
        <div class="stat-card shadow-lvl-2" style="text-align:center;">
          <div class="stat-label">Technical</div>
          <div class="stat-value" style={`color:${scoreColorHex(interview.techScore)};`}>{interview.techScore}</div>
          <div class="progress" style="margin-top:8px;"><div class="progress-bar" style={`width:${interview.techScore}%;background:${scoreColorHex(interview.techScore)};`}></div></div>
        </div>
        <div class="stat-card shadow-lvl-2" style="text-align:center;">
          <div class="stat-label">Confidence</div>
          <div class="stat-value" style={`color:${scoreColorHex(interview.confidenceScore)};`}>{interview.confidenceScore}</div>
          <div class="progress" style="margin-top:8px;"><div class="progress-bar" style={`width:${interview.confidenceScore}%;background:${scoreColorHex(interview.confidenceScore)};`}></div></div>
        </div>
      </div>

      <div class="grid-main-aside" style="--aside-w:320px;">
        <div style="display:flex;flex-direction:column;gap:20px;">
          <div class="card shadow-lvl-2">
            <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              AI Interview Analysis
              {interview.analysis && <span class={`badge ${interview.analysis.decision === 'advance' ? 'badge-success' : 'badge-error'}`} style="font-size:10px;text-transform:none;letter-spacing:0;font-family:inherit;">{interview.analysis.decision === 'advance' ? 'Recommends advancing' : 'Recommends holding'}</span>}
              {interview.analysis && (
                <button id="reanalyze-interview-btn" class="btn btn-ghost btn-sm" style="margin-left:auto;font-size:11px;text-transform:none;letter-spacing:0;font-family:inherit;font-weight:400;padding:4px 10px;height:auto;">
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none" style="margin-right:4px;"><path d="M12.5 7A5.5 5.5 0 1 1 10.5 2.8M12.5 2.5v3h-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Re-analyze with latest engine
                </button>
              )}
            </h2>
            {interview.analysis ? (
              <>
                <div style="background:var(--bg-soft);border-radius:6px;padding:16px;border-left:3px solid var(--fg);margin-bottom:16px;">
                  <p style="font-size:14px;color:var(--fg-body);line-height:1.6;margin:0;">{interview.analysis.reasoning}</p>
                </div>
                <div class="grid-cols-2" style="gap:16px;">
                  <div>
                    <h3 style="font-size:12px;font-weight:600;color:#10b981;margin:0 0 8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Strengths</h3>
                    {interview.analysis.strengths?.length ? (
                      <ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:6px;">
                        {interview.analysis.strengths.map((s: string) => <li style="font-size:13px;color:var(--fg-body);line-height:1.4;">{s}</li>)}
                      </ul>
                    ) : <p style="font-size:13px;color:var(--fg-mute);margin:0;">None detected in the feedback.</p>}
                  </div>
                  <div>
                    <h3 style="font-size:12px;font-weight:600;color:#ef4444;margin:0 0 8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Concerns</h3>
                    {interview.analysis.concerns?.length ? (
                      <ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:6px;">
                        {interview.analysis.concerns.map((s: string) => <li style="font-size:13px;color:var(--fg-body);line-height:1.4;">{s}</li>)}
                      </ul>
                    ) : <p style="font-size:13px;color:var(--fg-mute);margin:0;">None detected in the feedback.</p>}
                  </div>
                </div>
              </>
            ) : (
              <div style="background:var(--bg-soft);border-radius:6px;padding:16px;border:1px dashed var(--border);">
                <p style="font-size:13px;color:var(--fg-body);line-height:1.6;margin:0 0 12px;">This interview was marked completed before detailed feedback was captured, so there's no AI analysis on file — that's also why the feedback and transcript sections below are empty. Add the interviewer's real account now and the system will generate a genuine, text-grounded verdict from it.</p>
                <button id="add-feedback-btn" class="btn btn-primary btn-sm">Add Feedback &amp; Analyze</button>
              </div>
            )}
          </div>

          <div class="card shadow-lvl-2">
            <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Interviewer Feedback</h2>
            {interview.feedback ? (
              <p style="font-size:13px;color:var(--fg-body);line-height:1.6;margin:0;white-space:pre-wrap;">{interview.feedback}</p>
            ) : (
              <p style="font-size:13px;color:var(--fg-mute);margin:0;">No feedback recorded.</p>
            )}
            {interview.transcriptSummary && (
              <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
                <h3 style="font-size:12px;font-weight:600;color:var(--fg-mute);margin:0 0 8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Transcript</h3>
                <p style="font-size:13px;color:var(--fg-mute);line-height:1.6;margin:0 0 8px;">{interview.transcriptSummary}</p>
                {interview.transcript && (
                  <details>
                    <summary style="font-size:12px;color:var(--fg-mute);cursor:pointer;">View full transcript</summary>
                    <p style="font-size:12px;color:var(--fg-body);line-height:1.6;margin:8px 0 0;white-space:pre-wrap;background:var(--bg-soft);border-radius:6px;padding:12px;max-height:320px;overflow:auto;">{interview.transcript}</p>
                  </details>
                )}
              </div>
            )}
            {interview.notes && (
              <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
                <h3 style="font-size:12px;font-weight:600;color:var(--fg-mute);margin:0 0 8px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Pre-Interview Notes</h3>
                <p style="font-size:13px;color:var(--fg-body);line-height:1.6;margin:0;">{interview.notes}</p>
              </div>
            )}
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:16px;">
          <div class="card shadow-lvl-2">
            <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Final Recommendation</h3>
            <div style="font-size:18px;font-weight:600;color:var(--fg);margin-bottom:8px;">{interview.recommendation || 'Not set'}</div>
            <span class={`badge ${interview.recommendation?.includes('Strong') ? 'badge-success' : interview.recommendation === 'Do Not Recommend' ? 'badge-error' : 'badge-neutral'}`} style="font-size:12px;padding:4px 12px;">{interview.recommendation || '—'}</span>
          </div>
          <div class="card shadow-lvl-2">
            <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Suggested Next Step</h3>
            <p style="font-size:12px;color:var(--fg-mute);margin:0 0 12px;line-height:1.5;">
              {interview.candidateRejected
                ? `${interview.candidateName} has since been rejected — the process for them has ended, so no further rounds should be scheduled regardless of how this interview went.`
                : interview.analysis?.decision === 'advance'
                  ? 'The analysis leans toward moving this candidate forward — schedule the next round when ready.'
                  : interview.analysis
                    ? 'The analysis leans toward holding here — review the concerns above before deciding whether to reject or give another chance.'
                    : 'Review the recommendation above, then choose how to proceed.'}
            </p>
            <div style="display:flex;flex-direction:column;gap:8px;">
              {nextCanScheduleInterview && (
                <a href={`/interviews/schedule?candidate=${interview.candidateId}`} class="btn btn-primary" style="width:100%;border-radius:6px;">Schedule Next Interview</a>
              )}
              {nextCanScheduleAssessment && (
                <a href={`/assessments/create?candidate=${interview.candidateId}`} class="btn btn-primary" style="width:100%;border-radius:6px;">Create Assessment</a>
              )}
              <a href={`/candidates/${interview.candidateId}`} class={`btn ${(!nextCanScheduleInterview && !nextCanScheduleAssessment) ? 'btn-primary' : 'btn-secondary'}`} style="width:100%;border-radius:6px;">View Candidate</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="grid-main-aside" style="--aside-w:320px;">
      <div class="card shadow-lvl-2">
        <h2 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 16px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Interview Guide</h2>
        <div style="display:flex;flex-direction:column;gap:12px;max-height:560px;overflow-y:auto;padding-right:6px;">
          {guideSteps.map((step, i) => (
            <div style="display:flex;gap:12px;align-items:flex-start;">
              <div style="width:22px;height:22px;border-radius:50%;background:var(--bg-soft);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;flex-shrink:0;margin-top:1px;border:1px solid var(--border);">{i + 1}</div>
              <div style="font-size:13px;color:var(--fg-body);line-height:1.5;">
                <div style="font-weight:600;color:var(--fg);margin-bottom:2px;">{step.title}</div>
                <div>{step.detail}</div>
                {step.questions && step.questions.length > 0 && (
                  <ul style="margin:6px 0 0;padding-left:18px;color:var(--fg-mute);">
                    {step.questions.map(q => (
                      <li style="margin-bottom:2px;">{q}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ))}
        </div>
        {interview.notes && (
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
            <div style="font-size:12px;font-weight:600;color:var(--fg-mute);margin-bottom:6px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Notes</div>
            <p style="font-size:13px;color:var(--fg-body);line-height:1.5;margin:0;">{interview.notes}</p>
          </div>
        )}
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="card shadow-lvl-2">
          <h3 style="font-size:13px;font-weight:600;color:var(--fg-mute);margin:0 0 14px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.04em;">Actions</h3>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <button id="complete-btn-side" class="btn btn-primary" style="width:100%;border-radius:6px;">Mark as Completed</button>
            <button id="cancel-btn" class="btn btn-ghost" style="width:100%;color:#ee0000;">Cancel Interview</button>
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- Complete modal -->
  <div id="complete-modal" style="display:none;position:fixed;inset:0;z-index:100;align-items:center;justify-content:center;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.6);" id="modal-overlay"></div>
    <div class="card shadow-lvl-5" style="position:relative;z-index:1;width:560px;max-width:calc(100vw - 32px);max-height:calc(100vh - 64px);overflow:auto;">
      <h2 style="font-size:16px;font-weight:600;color:var(--fg);margin:0 0 6px;">Complete Interview</h2>
      <p style="font-size:12px;color:var(--fg-mute);margin:0 0 20px;line-height:1.5;">
        Describe what actually happened — the AI analyzes your account (and the transcript, if you have one) and produces the scores, strengths, concerns, and a move-forward recommendation. It does not guess from nothing, so be specific.
      </p>
      <div style="margin-bottom:16px;">
        <label style="font-size:12px;font-weight:500;color:var(--fg-mute);display:block;margin-bottom:6px;">Your Feedback / Comments <span style="color:#ee0000;">*</span></label>
        <textarea id="interview-feedback" class="input" style="height:140px;padding:10px 12px;resize:vertical;" placeholder="How did they do technically? How did they communicate? Did they seem confident under pressure? Would you move them forward — and why or why not? Be concrete: specific moments, answers, and your honest read carry the most weight."></textarea>
        <p id="feedback-hint" style="font-size:11px;color:var(--fg-mute);margin:4px 0 0;"></p>
      </div>
      <div style="margin-bottom:20px;">
        <label style="font-size:12px;font-weight:500;color:var(--fg-mute);display:block;margin-bottom:6px;">Video / Call Transcript (optional)</label>
        <textarea id="interview-transcript" class="input" style="height:110px;padding:10px 12px;resize:vertical;font-size:12px;" placeholder="Paste the transcript here if one is available — it gets scanned alongside your feedback for a fuller picture."></textarea>
      </div>
      <div id="modal-error" style="display:none;font-size:12px;color:#ee0000;margin-bottom:14px;"></div>
      <div style="display:flex;gap:10px;justify-content:flex-end;">
        <button id="modal-cancel" class="btn btn-secondary">Cancel</button>
        <button id="modal-save" class="btn btn-primary">Analyze &amp; Complete</button>
      </div>
    </div>
  </div>
</AppLayout>

<script define:vars={{ interviewId: interview.id }}>
  const modal = document.getElementById('complete-modal');

  function openModal() { modal.style.display = 'flex'; }
  function closeModal() { modal.style.display = 'none'; }

  document.getElementById('complete-btn')?.addEventListener('click', openModal);
  document.getElementById('complete-btn-side')?.addEventListener('click', openModal);
  document.getElementById('add-feedback-btn')?.addEventListener('click', openModal);
  document.getElementById('add-feedback-btn-top')?.addEventListener('click', openModal);
  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
  document.getElementById('modal-overlay')?.addEventListener('click', closeModal);

  const feedbackInput = document.getElementById('interview-feedback');
  const feedbackHint = document.getElementById('feedback-hint');
  feedbackInput?.addEventListener('input', () => {
    const len = feedbackInput.value.trim().length;
    feedbackHint.textContent = len === 0 ? '' : len < 15 ? `${len} characters — add a bit more so the analysis has something real to work with.` : '';
  });

  document.getElementById('modal-save')?.addEventListener('click', async () => {
    const btn = document.getElementById('modal-save');
    const errorEl = document.getElementById('modal-error');
    errorEl.style.display = 'none';

    const feedback = feedbackInput.value.trim();
    if (feedback.length < 15) {
      errorEl.textContent = 'Add a bit more detail to your feedback (at least a sentence or two) before analyzing.';
      errorEl.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Analyzing…';

    const payload = {
      status: 'completed',
      feedback,
      transcript: document.getElementById('interview-transcript').value.trim(),
    };

    const res = await fetch(`/api/interviews/${interviewId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      window.location.reload();
    } else {
      const err = await res.json().catch(() => ({}));
      errorEl.textContent = err.error || 'Failed to complete interview.';
      errorEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Analyze & Complete';
    }
  });

  document.getElementById('cancel-btn')?.addEventListener('click', async () => {
    const ok = await window.hvConfirm({
      title: 'Cancel interview',
      message: 'Cancel this interview?',
      confirmLabel: 'Cancel interview',
      destructive: true,
    });
    if (!ok) return;
    const res = await fetch(`/api/interviews/${interviewId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: 'cancelled' }),
    });
    if (res.ok) window.location.reload();
    else window.hvToast('Failed.', 'error');
  });

  document.getElementById('reanalyze-interview-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    btn.disabled = true;
    const original = btn.innerHTML;
    btn.textContent = 'Re-analyzing…';
    try {
      const res = await fetch(`/api/interviews/${interviewId}/reanalyze`, { method: 'POST' });
      if (res.ok) {
        window.hvToast('Interview re-analyzed with the latest engine.', 'success');
        window.location.reload();
      } else {
        const err = await res.json().catch(() => ({}));
        window.hvToast(err.error || 'Failed to re-analyze this interview.', 'error');
        btn.disabled = false;
        btn.innerHTML = original;
      }
    } catch {
      window.hvToast('Failed to re-analyze this interview.', 'error');
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });
</script>
