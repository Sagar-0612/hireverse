---
import AppLayout from "../layouts/AppLayout.astro";
import { connectDB } from "../db/connection";
import { Job } from "../db/models/Job";
import { Candidate } from "../db/models/Candidate";
import { Interview } from "../db/models/Interview";
import { Assessment } from "../db/models/Assessment";
import { ActivityLog } from "../db/models/ActivityLog";
import { bucketForCandidate, getIconSvg, type FunnelBucket } from "../lib/pipeline";
import { isOverdue } from "../lib/scheduling";

await connectDB();

// Pull every candidate with its parent job's pipeline so we can bucket by
// relative position in *that job's own* pipeline — the only way to build a
// cross-job funnel when each job can define totally different stages.
const allCandidates = await Candidate.find({}, 'jobId currentStage rejected rejectedAt stageHistory createdAt updatedAt')
  .populate('jobId', 'pipeline')
  .lean();

const bucketCounts: Record<FunnelBucket, number> = { Applied: 0, 'In Progress': 0, Hired: 0, Rejected: 0 };
const hiredCandidates: typeof allCandidates = [];
for (const c of allCandidates) {
  const pipeline = (c.jobId as any)?.pipeline || [];
  const bucket = bucketForCandidate(c, pipeline);
  bucketCounts[bucket]++;
  if (bucket === 'Hired') hiredCandidates.push(c);
}

const totalCandidates = allCandidates.length;
const activeCandidates = allCandidates.filter(c => !c.rejected).length;
const hiredCount = hiredCandidates.length;
const hiringRate = totalCandidates ? Math.round((hiredCount / totalCandidates) * 100) : 0;

const [totalJobs, activeJobsCount, scheduledCount] = await Promise.all([
  Job.countDocuments(),
  Job.countDocuments({ status: { $in: ['active', 'interviewing'] } }),
  Interview.countDocuments({ status: 'scheduled' }),
]);

const totalForFunnel = totalCandidates || 1;
const funnelOrder: FunnelBucket[] = ['Applied', 'In Progress', 'Hired', 'Rejected'];
const funnelData = funnelOrder.map(stage => ({
  stage,
  count: bucketCounts[stage],
  pct: Math.round((bucketCounts[stage] / totalForFunnel) * 100),
}));

// Top jobs
const topJobsRaw = await Job.find({ status: { $in: ['active', 'interviewing'] } })
  .sort({ createdAt: -1 }).limit(4).lean();
const topJobs = await Promise.all(topJobsRaw.map(async j => ({
  id: j._id.toString(),
  title: j.title,
  department: j.department,
  location: j.location,
  status: j.status,
  applicants: await Candidate.countDocuments({ jobId: j._id }),
})));

// Upcoming interviews
const upcomingRaw = await Interview.find({ status: 'scheduled' })
  .populate('candidateId', 'name')
  .populate('jobId', 'title')
  .sort({ date: 1 })
  .limit(3)
  .lean();
const upcoming = upcomingRaw.map(iv => ({
  id: iv._id.toString(),
  candidateName: (iv.candidateId as any)?.name || 'Unknown',
  jobTitle: (iv.jobId as any)?.title || '',
  round: iv.round,
  date: iv.date,
  time: iv.time,
  interviewer: iv.interviewer,
}));

// Recent activity — sourced directly from the real, persisted audit trail.
const recentLogs = await ActivityLog.find().sort({ createdAt: -1 }).limit(8).lean();
const ACTIVITY_ICON: Record<string, string> = { job: 'briefcase', candidate: 'user', interview: 'calendar', stage: 'flag', team: 'user' };
const recentActivity = recentLogs.map(l => ({
  text: l.message,
  time: new Date(l.createdAt).toLocaleDateString(),
  icon: ACTIVITY_ICON[l.type] || 'circle',
}));

// "Needs Attention" — the operational, action-oriented view that the
// historical/aggregate Analytics page deliberately does NOT show: anything
// overdue right now that a recruiter should act on today.
const overdueInterviewsRaw = await Interview.find({ status: { $in: ['scheduled', 'rescheduled'] } })
  .populate('candidateId', 'name')
  .populate('jobId', 'title')
  .lean();
const overdueInterviews = overdueInterviewsRaw
  .filter(iv => isOverdue(iv.date, iv.time, true))
  .map(iv => ({
    id: iv._id.toString(),
    candidateName: (iv.candidateId as any)?.name || 'Unknown',
    jobTitle: (iv.jobId as any)?.title || '',
    round: iv.round,
    date: iv.date,
    time: iv.time,
  }));

const overdueAssessmentsRaw = await Assessment.find({ status: { $ne: 'evaluated' } })
  .populate('candidateId', 'name')
  .populate('jobId', 'title')
  .lean();
const overdueAssessments = overdueAssessmentsRaw
  .filter(a => isOverdue(a.dueDate || '', a.dueTime || '', true))
  .map(a => ({
    id: a._id.toString(),
    candidateName: (a.candidateId as any)?.name || 'Unknown',
    jobTitle: (a.jobId as any)?.title || '',
    round: a.round,
    dueDate: a.dueDate,
  }));

const needsAttention = [
  ...overdueInterviews.map(iv => ({ ...iv, kind: 'interview' as const, href: `/interviews/${iv.id}`, label: `${iv.round} overdue — was ${iv.date} ${iv.time}` })),
  ...overdueAssessments.map(a => ({ ...a, kind: 'assessment' as const, href: `/assessments/${a.id}`, label: `${a.round} overdue — due ${a.dueDate}` })),
].slice(0, 6);
const needsAttentionTotal = overdueInterviews.length + overdueAssessments.length;
---

<AppLayout title="Dashboard" activeNav="dashboard">
  <div style="margin-bottom:28px;">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
      <div>
        <h1 style="font-size:24px;font-weight:600;color:var(--fg);letter-spacing:-0.5px;margin:0 0 4px;">Dashboard</h1>
        <p style="font-size:14px;color:var(--fg-mute);margin:0;">{new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}</p>
      </div>
      <div style="display:flex;gap:8px;">
        <a href="/jobs/new" class="btn btn-secondary btn-sm">+ New Job</a>
        <a href="/jobs" class="btn btn-primary btn-sm">View All Jobs</a>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:28px;">
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Total Jobs</div>
      <div class="stat-value">{totalJobs}</div>
      <div class="stat-delta">{activeJobsCount} active</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Active Candidates</div>
      <div class="stat-value">{activeCandidates}</div>
      <div class="stat-delta">{totalCandidates} total</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Interviews Scheduled</div>
      <div class="stat-value">{scheduledCount}</div>
      <div class="stat-delta">upcoming</div>
    </div>
    <div class="stat-card shadow-lvl-2">
      <div class="stat-label">Hiring Success Rate</div>
      <div class="stat-value">{hiringRate}%</div>
      <div class="stat-delta up">{hiredCount} hired total</div>
    </div>
  </div>

  <!-- Main grid -->
  <div class="grid-main-aside" style="--aside-w:360px;">
    <div style="display:flex;flex-direction:column;gap:20px;">
      <!-- Hiring Funnel -->
      <div class="card shadow-lvl-2">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
          <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Hiring Funnel</h2>
          <span class="badge badge-neutral" style="font-size:11px;font-family:'JetBrains Mono',monospace;">All Jobs</span>
        </div>
        {funnelData.map(row => (
          <div class="funnel-row">
            <span class="funnel-label">{row.stage}</span>
            <div class="funnel-track"><div class="funnel-fill" style={`width:${Math.max(row.pct, row.count > 0 ? 4 : 0)}%`}></div></div>
            <span class="funnel-count">{row.count}</span>
          </div>
        ))}
      </div>

      <!-- Top Jobs -->
      <div class="card shadow-lvl-2">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
          <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Top Performing Jobs</h2>
          <a href="/jobs" class="btn btn-ghost btn-sm">View all</a>
        </div>
        {topJobs.length === 0 ? (
          <div style="text-align:center;padding:24px;color:var(--fg-mute);font-size:13px;">No jobs yet. <a href="/jobs/new" style="color:var(--fg);">Create one →</a></div>
        ) : (
          <div style="display:flex;flex-direction:column;gap:12px;">
            {topJobs.map((job, idx) => (
              <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:24px;height:24px;border-radius:6px;background:var(--bg-soft-2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;flex-shrink:0;">{idx+1}</div>
                <div style="flex:1;min-width:0;">
                  <a href={`/jobs/${job.id}`} style="font-size:14px;font-weight:500;color:var(--fg);text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{job.title}</a>
                  <div style="font-size:12px;color:var(--fg-mute);">{job.department} · {job.location}</div>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                  <div style="font-size:14px;font-weight:600;color:var(--fg);font-family:'JetBrains Mono',monospace;">{job.applicants}</div>
                  <div style="font-size:11px;color:var(--fg-mute);">applicants</div>
                </div>
                <span class={`badge ${job.status === 'active' ? 'badge-success' : 'badge-info'}`}>{job.status}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Needs Attention -->
      <div class="card shadow-lvl-2">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
          <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Needs Attention</h2>
          {needsAttentionTotal > 0 && <span class="badge badge-error" style="font-size:11px;">{needsAttentionTotal} overdue</span>}
        </div>
        {needsAttention.length === 0 ? (
          <div style="text-align:center;padding:20px;color:var(--fg-mute);font-size:13px;">Nothing overdue — all interviews and assessments are on schedule.</div>
        ) : (
          <div style="display:flex;flex-direction:column;gap:10px;">
            {needsAttention.map(item => (
              <a href={item.href} style="display:flex;gap:12px;padding:10px;border-radius:6px;background:var(--bg-soft);text-decoration:none;border:1px solid var(--border);">
                <div style="flex-shrink:0;width:36px;height:36px;border-radius:6px;background:#ef444422;display:flex;align-items:center;justify-content:center;color:#ef4444;">
                  <span set:html={getIconSvg(item.kind === 'interview' ? 'calendar' : 'flag')} style="display:inline-flex;width:14px;height:14px;" />
                </div>
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:500;color:var(--fg);">{item.candidateName} <span style="color:var(--fg-mute);font-weight:400;">· {item.jobTitle}</span></div>
                  <div style="font-size:12px;color:#ef4444;margin-top:2px;">{item.label}</div>
                </div>
              </a>
            ))}
          </div>
        )}
        {needsAttentionTotal > needsAttention.length && (
          <div style="margin-top:10px;text-align:center;">
            <a href="/interviews" class="btn btn-ghost btn-sm">View all overdue →</a>
          </div>
        )}
      </div>
    </div>

    <!-- Right column -->
    <div style="display:flex;flex-direction:column;gap:20px;">
      <!-- Upcoming Interviews -->
      <div class="card shadow-lvl-2">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Upcoming Interviews</h2>
          <a href="/interviews" class="btn btn-ghost btn-sm">View all</a>
        </div>
        {upcoming.length === 0 ? (
          <div style="text-align:center;padding:20px;color:var(--fg-mute);font-size:13px;">No interviews scheduled.</div>
        ) : (
          <div style="display:flex;flex-direction:column;gap:10px;">
            {upcoming.map(iv => (
              <a href={`/interviews/${iv.id}`} style="display:flex;gap:12px;padding:10px;border-radius:6px;background:var(--bg-soft);text-decoration:none;border:1px solid var(--border);">
                <div style="flex-shrink:0;width:36px;height:36px;border-radius:6px;background:var(--bg-soft-2);display:flex;flex-direction:column;align-items:center;justify-content:center;">
                  <div style="font-size:10px;font-weight:600;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;line-height:1;">{iv.date.split('-')[2]}</div>
                  <div style="font-size:9px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;line-height:1;text-transform:uppercase;">{new Date(iv.date + 'T12:00:00').toLocaleString('en-US',{month:'short'})}</div>
                </div>
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:500;color:var(--fg);">{iv.candidateName}</div>
                  <div style="font-size:12px;color:var(--fg-mute);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{iv.round} · {iv.jobTitle}</div>
                  <div style="font-size:11px;color:var(--fg-mute);margin-top:2px;">{iv.time} · {iv.interviewer}</div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Recent Activity -->
      <div class="card shadow-lvl-2">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;">
          <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0;">Recent Activity</h2>
          {recentActivity.length > 0 && (
            <button id="clear-activity-btn" class="btn btn-ghost btn-sm" style="color:var(--fg-mute);">Clear</button>
          )}
        </div>
        {recentActivity.length === 0 ? (
          <div id="activity-empty" style="text-align:center;padding:20px;color:var(--fg-mute);font-size:13px;">No recent activity.</div>
        ) : (
          <div id="activity-list" class="scroll-list">
            {recentActivity.map((act, idx) => (
              <div class="activity-row" style={`display:flex;gap:12px;padding:10px 0;${idx < recentActivity.length - 1 ? 'border-bottom:1px solid var(--border);' : ''}`}>
                <div style="width:28px;height:28px;border-radius:6px;background:var(--bg-soft-2);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--fg-mute);">
                  <span set:html={getIconSvg(act.icon)} style="display:inline-flex;width:13px;height:13px;" />
                </div>
                <div>
                  <div style="font-size:13px;color:var(--fg-body);line-height:1.4;">{act.text}</div>
                  <div style="font-size:11px;color:var(--fg-mute);margin-top:2px;font-family:'JetBrains Mono',monospace;">{act.time}</div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</AppLayout>

<script>
  const clearBtn = document.getElementById('clear-activity-btn') as HTMLButtonElement | null;
  clearBtn?.addEventListener('click', async () => {
    const ok = await (window as any).hvConfirm({
      title: 'Clear recent activity',
      message: 'This permanently deletes the entire activity log. This cannot be undone.',
      confirmLabel: 'Clear all',
      destructive: true,
    });
    if (!ok) return;

    clearBtn.disabled = true;
    const res = await fetch('/api/activity', { method: 'DELETE' });
    if (res.ok) {
      const list = document.getElementById('activity-list');
      const card = clearBtn.closest('.card');
      if (list) list.remove();
      const empty = document.createElement('div');
      empty.id = 'activity-empty';
      empty.style.cssText = 'text-align:center;padding:20px;color:var(--fg-mute);font-size:13px;';
      empty.textContent = 'No recent activity.';
      card?.appendChild(empty);
      clearBtn.remove();
      (window as any).hvToast('Activity log cleared.', 'success');
    } else {
      clearBtn.disabled = false;
      (window as any).hvToast('Failed to clear activity log.', 'error');
    }
  });
</script>
