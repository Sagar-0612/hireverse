---
import "../styles/global.css";

export interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = "" } = Astro.props;

const navItems = [
  { href: "/dashboard", label: "Dashboard", id: "dashboard", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>` },
  { href: "/jobs", label: "Jobs", id: "jobs", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="5" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M5 5V4a3 3 0 0 1 6 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>` },
  { href: "/candidates", label: "Candidates", id: "candidates", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 14c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>` },
  { href: "/interviews", label: "Interviews", id: "interviews", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="2.5" width="13" height="12" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M1.5 6.5h13" stroke="currentColor" stroke-width="1.5"/><path d="M5 1v3M11 1v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>` },
  { href: "/analytics", label: "Analytics", id: "analytics", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 12l3.5-4 3 2.5L12 5l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>` },
  { href: "/team", label: "Team", id: "team", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="5.5" cy="5" r="2.5" stroke="currentColor" stroke-width="1.5"/><circle cx="10.5" cy="5" r="2.5" stroke="currentColor" stroke-width="1.5"/><path d="M1 14c0-2.485 2.015-4 4.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9 14c0-2.485 1.015-4 3.5-4s4 1.515 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>` },
  { href: "/settings", label: "Settings", id: "settings", icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 1v1.5M8 13.5V15M15 8h-1.5M2.5 8H1M12.364 3.636l-1.06 1.06M4.696 11.304l-1.06 1.06M12.364 12.364l-1.06-1.06M4.696 4.696l-1.06-1.06" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>` },
];
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — HireVerse AI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="app-shell">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <!-- Logo -->
      <div style="padding: 16px; border-bottom: 1px solid var(--sidebar-border); flex-shrink: 0;">
        <a href="/dashboard" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
          <div style="width:28px;height:28px;border-radius:6px;background:var(--fg);display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8l3 3 7-7" stroke="var(--bg)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <div style="font-size:14px;font-weight:600;color:var(--fg);line-height:1.2;">HireVerse</div>
            <div style="font-size:10px;color:var(--fg-mute);font-family:'JetBrains Mono',monospace;line-height:1;">AI Platform</div>
          </div>
        </a>
      </div>

      <!-- Nav -->
      <nav style="padding: 12px 10px; flex: 1;">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`nav-item ${activeNav === item.id ? "active" : ""}`}
          >
            <span set:html={item.icon} style="flex-shrink:0;opacity:0.7;" />
            {item.label}
          </a>
        ))}
      </nav>

      <!-- User -->
      <div style="padding: 12px 10px; border-top: 1px solid var(--sidebar-border); flex-shrink: 0;">
        <div style="display:flex;align-items:center;gap:10px;padding:8px;border-radius:6px;cursor:pointer;" class="nav-item">
          <div class="avatar" style="width:24px;height:24px;font-size:10px;">MK</div>
          <div style="min-width:0;">
            <div style="font-size:13px;font-weight:500;color:var(--fg);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Maya Kim</div>
            <div style="font-size:11px;color:var(--fg-mute);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Head of Talent</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <div class="main-content">
      <!-- Topbar -->
      <header class="topbar">
        <!-- Mobile menu -->
        <button id="mobile-menu-btn" class="btn btn-ghost" style="display:none;padding:0;width:32px;" aria-label="Menu">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>

        <!-- Search -->
        <div class="search-wrap" style="flex:1;max-width:360px;">
          <span class="search-icon">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 10l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </span>
          <input type="text" id="global-search-input" class="input search-input" placeholder="Search jobs, candidates…" style="height:32px;font-size:13px;" autocomplete="off" />
          <div id="global-search-results" class="search-results"></div>
        </div>

        <div style="flex:1;"></div>

        <!-- Actions -->
        <div style="display:flex;align-items:center;gap:8px;">
          <!-- Notifications -->
          <button class="btn btn-ghost" style="padding:0;width:32px;height:32px;position:relative;" aria-label="Notifications">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1a5 5 0 0 1 5 5v2l1.5 2.5H.5L2 8V6a5 5 0 0 1 5-5" stroke="currentColor" stroke-width="1.5"/><path d="M6.5 13.5a1.5 1.5 0 0 0 3 0" stroke="currentColor" stroke-width="1.5"/></svg>
            <span style="position:absolute;top:6px;right:6px;width:6px;height:6px;border-radius:50%;background:#ee0000;border:1.5px solid var(--bg);"></span>
          </button>

          <!-- Theme toggle -->
          <button id="theme-toggle" class="btn btn-ghost" style="padding:0;width:32px;height:32px;" aria-label="Toggle theme">
            <span id="icon-sun" style="display:none;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M12.95 3.05l-1.06 1.06M4.11 11.89l-1.06 1.06" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <span id="icon-moon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 10A6.5 6.5 0 0 1 6 2.5a6.5 6.5 0 1 0 7.5 7.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
          </button>

          <!-- Avatar -->
          <button class="btn btn-ghost" style="padding:0;border-radius:50%;" aria-label="User menu">
            <div class="avatar">MK</div>
          </button>
        </div>
      </header>

      <!-- Page content -->
      <main class="page-content">
        <slot />
      </main>
    </div>
  </div>

  <!-- Overlay for mobile sidebar -->
  <div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:49;"></div>

  <!-- Toast stack (window.hvToast) -->
  <div id="hv-toast-stack" aria-live="polite"></div>

  <!-- Confirm / prompt dialog (window.hvConfirm, window.hvPrompt) -->
  <div id="hv-confirm-overlay">
    <div class="hv-confirm-dialog" role="dialog" aria-modal="true">
      <h3 class="hv-confirm-title" id="hv-confirm-title"></h3>
      <p class="hv-confirm-message" id="hv-confirm-message"></p>
      <input class="input" id="hv-confirm-input" style="display:none;margin:-6px 0 16px;" />
      <div class="hv-confirm-actions">
        <button class="btn btn-ghost" id="hv-confirm-cancel">Cancel</button>
        <button class="btn btn-primary" id="hv-confirm-ok">Confirm</button>
      </div>
    </div>
  </div>

  <script>
    // Theme persistence
    (function() {
      const saved = localStorage.getItem("hv-theme");
      if (saved === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
    })();

    const toggle = document.getElementById("theme-toggle");
    const iconSun = document.getElementById("icon-sun");
    const iconMoon = document.getElementById("icon-moon");

    function updateIcons() {
      const isDark = document.documentElement.classList.contains("dark");
      if (iconSun && iconMoon) {
        iconSun.style.display = isDark ? "flex" : "none";
        iconMoon.style.display = isDark ? "none" : "flex";
      }
    }
    updateIcons();

    toggle?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("hv-theme", isDark ? "dark" : "light");
      updateIcons();
    });

    // Mobile sidebar
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebar-overlay");
    const menuBtn = document.getElementById("mobile-menu-btn");

    menuBtn?.addEventListener("click", () => {
      sidebar?.classList.toggle("open");
      if (sidebar?.classList.contains("open")) {
        overlay!.style.display = "block";
      } else {
        overlay!.style.display = "none";
      }
    });

    overlay?.addEventListener("click", () => {
      sidebar?.classList.remove("open");
      overlay.style.display = "none";
    });

    // Show mobile menu button on small screens
    function checkWidth() {
      if (menuBtn) {
        menuBtn.style.display = window.innerWidth <= 768 ? "flex" : "none";
      }
    }
    checkWidth();
    window.addEventListener("resize", checkWidth);

    // ── Toasts (window.hvToast) ──
    const TOAST_ICONS = {
      success: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M5.2 8.2l1.8 1.8 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      error: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3.5M8 11v.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
      info: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 7.5v3.5M8 5v.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
    };
    const toastStack = document.getElementById("hv-toast-stack");
    window.hvToast = function(message, type) {
      type = (type === "success" || type === "error") ? type : "info";
      const el = document.createElement("div");
      el.className = `hv-toast hv-toast-${type}`;
      el.innerHTML = `<span class="hv-toast-icon">${TOAST_ICONS[type]}</span><span class="hv-toast-msg"></span><button class="hv-toast-close" aria-label="Dismiss"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3.5 3.5l7 7M10.5 3.5l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>`;
      el.querySelector(".hv-toast-msg").textContent = message;
      let dismissed = false;
      const close = () => {
        if (dismissed) return;
        dismissed = true;
        el.classList.remove("show");
        setTimeout(() => el.remove(), 220);
      };
      el.querySelector(".hv-toast-close")?.addEventListener("click", close);
      toastStack?.appendChild(el);
      requestAnimationFrame(() => el.classList.add("show"));
      setTimeout(close, 5000);
    };

    // ── Confirm / prompt dialog (window.hvConfirm, window.hvPrompt) ──
    const confirmOverlay = document.getElementById("hv-confirm-overlay");
    const confirmTitleEl = document.getElementById("hv-confirm-title");
    const confirmMessageEl = document.getElementById("hv-confirm-message");
    const confirmInputEl = document.getElementById("hv-confirm-input");
    const confirmOkBtn = document.getElementById("hv-confirm-ok");
    const confirmCancelBtn = document.getElementById("hv-confirm-cancel");
    let confirmResolve = null;

    function closeDialog(result) {
      confirmOverlay?.classList.remove("show");
      const resolve = confirmResolve;
      confirmResolve = null;
      if (resolve) resolve(result);
    }

    function openDialog(opts) {
      return new Promise((resolve) => {
        confirmResolve = resolve;
        if (confirmTitleEl) {
          confirmTitleEl.textContent = opts.title || "";
          confirmTitleEl.style.display = opts.title ? "" : "none";
        }
        if (confirmMessageEl) {
          confirmMessageEl.textContent = opts.message || "";
          confirmMessageEl.style.display = opts.message ? "" : "none";
        }
        if (confirmInputEl) {
          if (opts.withInput) {
            confirmInputEl.style.display = "";
            confirmInputEl.value = opts.defaultValue || "";
            confirmInputEl.placeholder = opts.placeholder || "";
          } else {
            confirmInputEl.style.display = "none";
          }
        }
        if (confirmOkBtn) {
          confirmOkBtn.textContent = opts.confirmLabel || "Confirm";
          confirmOkBtn.className = opts.destructive ? "btn btn-destructive" : "btn btn-primary";
        }
        if (confirmCancelBtn) confirmCancelBtn.textContent = opts.cancelLabel || "Cancel";
        confirmOverlay?.classList.add("show");
        setTimeout(() => (opts.withInput ? confirmInputEl : confirmOkBtn)?.focus(), 50);
      });
    }

    confirmOkBtn?.addEventListener("click", () => closeDialog("ok"));
    confirmCancelBtn?.addEventListener("click", () => closeDialog("cancel"));
    confirmOverlay?.addEventListener("click", (e) => { if (e.target === confirmOverlay) closeDialog("cancel"); });
    confirmInputEl?.addEventListener("keydown", (e) => { if (e.key === "Enter") closeDialog("ok"); });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && confirmOverlay?.classList.contains("show")) closeDialog("cancel");
    });

    window.hvConfirm = function(opts) {
      const o = typeof opts === "string" ? { message: opts } : (opts || {});
      return openDialog({ ...o, withInput: false }).then((r) => r === "ok");
    };

    window.hvPrompt = function(opts) {
      const o = typeof opts === "string" ? { message: opts } : (opts || {});
      return openDialog({ ...o, withInput: true }).then((r) => (r === "ok" ? confirmInputEl.value : null));
    };

    // ── Global search (topbar) ──
    const searchInput = document.getElementById("global-search-input");
    const searchResults = document.getElementById("global-search-results");

    function escapeHtml(s) {
      return String(s ?? "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    }

    function renderSearchResults(data, query) {
      if (!searchResults) return;
      const jobs = data.jobs || [];
      const candidates = data.candidates || [];
      if (!jobs.length && !candidates.length) {
        searchResults.innerHTML = `<div class="search-results-empty">No jobs or candidates match "${escapeHtml(query)}"</div>`;
        searchResults.classList.add("show");
        return;
      }
      let html = "";
      if (jobs.length) {
        html += `<div class="search-results-group-label">Jobs</div>`;
        for (const j of jobs) {
          const meta = [j.department, j.location].filter(Boolean).join(" · ");
          html += `<a class="search-result-item" href="/jobs/${j._id}">
            <span class="search-result-title">${escapeHtml(j.title)}</span>
            <span class="search-result-meta">${escapeHtml(meta || "Job")}</span>
          </a>`;
        }
      }
      if (candidates.length) {
        html += `<div class="search-results-group-label">Candidates</div>`;
        for (const c of candidates) {
          const meta = [c.currentStage, c.location].filter(Boolean).join(" · ");
          html += `<a class="search-result-item" href="/candidates/${c._id}">
            <span class="search-result-title">${escapeHtml(c.name)}</span>
            <span class="search-result-meta">${escapeHtml(meta || c.email || "Candidate")}</span>
          </a>`;
        }
      }
      searchResults.innerHTML = html;
      searchResults.classList.add("show");
    }

    let searchDebounce = null;
    let searchAbort = null;
    let searchSeq = 0;

    function runSearch(query) {
      const seq = ++searchSeq;
      if (searchAbort) searchAbort.abort();
      const controller = new AbortController();
      searchAbort = controller;
      fetch(`/api/search?q=${encodeURIComponent(query)}`, { signal: controller.signal })
        .then((res) => (res.ok ? res.json() : Promise.reject(new Error("Search failed"))))
        .then((data) => {
          if (seq !== searchSeq) return;
          renderSearchResults(data, query);
        })
        .catch((err) => {
          if (err?.name === "AbortError" || seq !== searchSeq) return;
          if (searchResults) {
            searchResults.innerHTML = `<div class="search-results-empty">Search is unavailable right now — try again in a moment.</div>`;
            searchResults.classList.add("show");
          }
        });
    }

    searchInput?.addEventListener("input", () => {
      const query = searchInput.value.trim();
      if (searchDebounce) clearTimeout(searchDebounce);
      if (query.length < 2) {
        searchResults?.classList.remove("show");
        if (searchAbort) searchAbort.abort();
        return;
      }
      searchDebounce = setTimeout(() => runSearch(query), 250);
    });

    searchInput?.addEventListener("focus", () => {
      if (searchInput.value.trim().length >= 2 && searchResults?.innerHTML) {
        searchResults.classList.add("show");
      }
    });

    document.addEventListener("click", (e) => {
      if (!searchResults || !searchInput) return;
      if (e.target === searchInput || searchResults.contains(e.target)) return;
      searchResults.classList.remove("show");
    });

    searchInput?.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        searchResults?.classList.remove("show");
        searchInput.blur();
      } else if (e.key === "Enter") {
        const first = searchResults?.querySelector(".search-result-item");
        if (first) {
          e.preventDefault();
          window.location.href = first.getAttribute("href");
        }
      }
    });
  </script>
</body>
</html>
