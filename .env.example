# Copy this file to .env and fill in your own MongoDB connection string.
# Option 1 – local MongoDB:
MONGODB_URI=mongodb://localhost:27017/hireverse
# Option 2 – MongoDB Atlas (recommended for sharing across machines):
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/hireverse

# ── Notifications (all optional) ─────────────────────────────────────────────
# Email (interview/assessment scheduling notifications via SMTP/nodemailer).
# If SMTP_HOST is left unset, notifications are logged to the console instead
# of sent — the rest of the app works fine without these.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# SMTP_FROM=HireVerse <noreply@example.com>

# WhatsApp (via Twilio's WhatsApp API). If unset, messages are logged instead
# of sent.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_WHATSAPP_FROM=+14155238886
